      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (provider) (count_over_time({log_type=\"llm_calls\"} | json | event=\"llm_call\" | run_id=~\"$run_id\" [$__range]))",
          "legendFormat": "{{provider}}",
          "queryType": "range",
