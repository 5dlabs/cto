    {
      "id": 8,
      "title": "LLM Call Log",
      "description": "Detailed log of all LLM calls for the selected run",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{log_type=\"llm_calls\"} | json | event=\"llm_call\" | run_id=~\"$run_id\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [
              { "id": "unit", "value": "ms" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "ok": { "text": "OK", "color": "green" }, "error": { "text": "ERROR", "color": "red" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "custom.width", "value": 250 }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "ts" }
        ]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "id": true,
              "tsNs": true,
              "labels": true,
              "event": true,
              "run_id": true,
              "log_type": true
            },
            "indexByName": {
              "ts": 0,
              "task_name": 1,
              "provider": 2,
              "model": 3,
              "status": 4,
              "duration_ms": 5,
              "attempt": 6,
              "cascade_position": 7,
              "error": 8
            },
            "renameByName": {
              "ts": "Timestamp",
              "task_name": "Task",
              "provider": "Provider",
              "model": "Model",
              "status": "Status",
              "duration_ms": "Duration",
              "attempt": "Attempt",
              "cascade_position": "Cascade Pos",
              "error": "Error"
            }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["intake", "llm", "models"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({log_type=\"runs\"}, run_id)",
        "allValue": ".*",
        "hide": 0,
        "includeAll": true,
        "label": "Run ID",
        "multi": false,
        "name": "run_id",
        "options": [],
        "query": "label_values({log_type=\"runs\"}, run_id)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "browser",
  "title": "LLM Model Usage",
  "uid": "llm-model-usage",
  "version": 1,
  "refresh": "10s"
}
