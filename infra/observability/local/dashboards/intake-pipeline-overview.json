  "schemaVersion": 39,
  "tags": ["intake", "pipeline", "overview"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({log_type=\"runs\"}, run_id)",
        "allValue": ".*",
        "hide": 0,
        "includeAll": true,
        "label": "Run ID",
        "multi": false,
        "name": "run_id",
        "options": [],
        "query": "label_values({log_type=\"runs\"}, run_id)",
        "refresh": 2,
        "regex": "",
