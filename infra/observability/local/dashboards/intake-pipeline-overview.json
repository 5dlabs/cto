{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Overview of CTO intake pipeline runs, steps, and LLM usage",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["intake"],
      "title": "Intake Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Run Status",
      "description": "Count of successful runs (exit_code=0) in the last 30 days",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "count_over_time({log_type=\"runs\"} | json | event=\"run_complete\" | exit_code=\"0\" [30d])",
          "legendFormat": "Successful",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "count_over_time({log_type=\"runs\"} | json | event=\"run_complete\" | exit_code!=\"0\" [30d])",
          "legendFormat": "Failed",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 2,
      "title": "Latest Run Duration",
      "description": "Duration of the selected run",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "last_over_time({log_type=\"runs\"} | json | event=\"run_complete\" | run_id=~\"$run_id\" | unwrap duration_sec | __error__=\"\" [$__range])",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1800 },
              { "color": "red", "value": 3600 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "title": "Active Steps",
      "description": "Steps started but not yet completed for the selected run",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "count_over_time({log_type=\"pipeline\"} | json | event=\"step_start\" | run_id=~\"$run_id\" [$__range])",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A",
          "hide": true
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "count_over_time({log_type=\"pipeline\"} | json | event=\"step_end\" | run_id=~\"$run_id\" [$__range])",
          "legendFormat": "",
          "queryType": "range",
          "refId": "B",
          "hide": true
        },
        {
          "datasource": { "type": "__expr__", "uid": "__expr__" },
          "expression": "$A - $B",
          "hide": false,
          "refId": "C",
          "type": "math"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "title": "Total LLM Calls",
      "description": "Total LLM call events for the selected run",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "count_over_time({log_type=\"llm_calls\"} | json | event=\"llm_call\" | run_id=~\"$run_id\" [$__range])",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "title": "Pipeline Phase Timeline",
      "description": "Step details for the selected run: step_id, phase, duration, and exit code",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{log_type=\"pipeline\"} | json | event=\"step_end\" | run_id=~\"$run_id\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_ms" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 300000 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "exit_code" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "OK", "color": "green" } } },
                  { "type": "special", "options": { "match": "null+nan", "result": { "text": "-", "color": "text" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [
          { "desc": false, "displayName": "ts" }
        ]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "id": true,
              "tsNs": true,
              "labels": true,
              "event": true,
              "run_id": true,
              "log_type": true
            },
            "indexByName": {
              "ts": 0,
              "step_id": 1,
              "phase": 2,
              "duration_ms": 3,
              "exit_code": 4
            },
            "renameByName": {
              "ts": "Timestamp",
              "step_id": "Step",
              "phase": "Phase",
              "duration_ms": "Duration (ms)",
              "exit_code": "Exit Code"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Step Durations",
      "description": "Duration of each pipeline step for the selected run",
      "type": "barchart",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "max by (step_id) (last_over_time({log_type=\"pipeline\"} | json | event=\"step_end\" | run_id=~\"$run_id\" | unwrap duration_ms | __error__=\"\" [$__range]))",
          "legendFormat": "{{step_id}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Duration (ms)",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60000 },
              { "color": "red", "value": 120000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.8,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 7,
      "title": "Errors",
      "description": "Pipeline step errors for the selected run",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki" },
