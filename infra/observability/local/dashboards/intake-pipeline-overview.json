          "expr": "{log_type=\"pipeline\"} | json | event=\"step_error\" | run_id=~\"$run_id\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": true,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "ts" }
        ]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "id": true,
              "tsNs": true,
              "labels": true,
              "event": true,
              "run_id": true,
              "log_type": true,
              "phase": true
            },
            "indexByName": {
              "ts": 0,
              "step_id": 1,
              "error": 2
            },
            "renameByName": {
              "ts": "Timestamp",
              "step_id": "Step",
              "error": "Error"
            }
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Run History",
      "description": "Recent completed runs with project, mode, duration, and exit code",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{log_type=\"runs\"} | json | event=\"run_complete\"",
          "legendFormat": "",
