{
  "name": "@jonathonfritz/mcp-investor-research",
  "version": "0.1.0",
  "description": "MCP server for researching early-stage investors and startup credits",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-investor-research": "./bin/server.sh"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "keywords.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pub": "npm publish --access restricted",
    "pub:beta": "npm publish --access restricted --tag beta"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "mcp",
    "anthropic",
    "investor",
    "startup",
    "vc",
    "x",
    "grok"
  ],
  "author": "Jonathon Fritz",
  "license": "MIT"
}
