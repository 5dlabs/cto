    "linear": {
      "teamId": "CTOPA",
      "pmServerUrl": "http://localhost:8081",
      "intake": {
        "createProject": true,
        "projectTemplate": "Play Workflow"
      }
    },
    "play": {
      "repository": "5dlabs/cto",
      "service": "cto",
      "docsRepository": "5dlabs/cto",
      "docsProjectDirectory": "docs",
      "workingDirectory": ".",
      "healerEndpoint": "http://localhost:8083",
      "autoMerge": true,
      "implementationMaxRetries": 10,
      "qualityMaxRetries": 5,
      "securityMaxRetries": 2,
      "testingMaxRetries": 5,
      "watcher": {
        "enabled": false,
        "cli": "factory",
        "model": "glm-4-plus",
        "checkIntervalSecs": 120,
        "template": "watcher/base",
        "circuitBreakerThreshold": 3
      }
    },
    "remediation": {
      "repository": "5dlabs/cto",
      "docsRepository": "5dlabs/cto",
      "docsProjectDirectory": "docs",
      "agent": "5DLabs-Rex",
      "cli": "claude",
      "model": "claude-opus-4-5-20251101",
      "maxIterations": 3,
      "template": "watch/factory",
      "syncTimeoutSecs": 300
    },
    "monitor": {
      "agent": "5DLabs-Rex",
      "cli": "factory",
      "model": "glm-4-plus",
      "template": "watch/factory",
      "maxIterations": 3
    },
    "stitch": {
      "enabled": true,
      "cli": "claude",
      "model": "claude-opus-4-5-20251101",
      "repos": [
