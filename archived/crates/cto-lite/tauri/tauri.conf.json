{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CTO",
  "identifier": "ai.5dlabs.cto",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CTO",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; frame-src 'self' http://localhost:* http://127.0.0.1:* https:; connect-src 'self' http://localhost:* http://127.0.0.1:* https: ws://localhost:* ws://127.0.0.1:* wss://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "category": "DeveloperTool",
    "shortDescription": "AI-powered development assistant",
    "longDescription": "CTO brings AI-powered development workflows to your desktop. Configure once, then use MCP from your IDE to create features, fix bugs, and ship code faster.",
    "copyright": "© 2025 5D Labs",
    "publisher": "5D Labs",
    "homepage": "https://cto.dev",
    "macOS": {
      "entitlements": "CTO.entitlements",
      "exceptionDomain": "",
      "frameworks": [],
      "infoPlist": "Info.plist",
      "providerShortName": "5DLabs",
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
