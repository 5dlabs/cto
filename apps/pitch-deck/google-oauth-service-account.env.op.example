# Optional: inject OP_SERVICE_ACCOUNT_TOKEN for unattended scripts (e.g. google-oauth-json-to-1password.sh).
# Copy to gitignored google-oauth-service-account.env.op and set the op:// line.
#
# The token must live in a 1Password item your *human* account can read; run once:
#   eval "$(op signin)"
#   export OP_SERVICE_ACCOUNT_TOKEN="$(op read 'op://YOUR_VAULT/Your Service Account Item/credential')"
#   ./scripts/google-oauth-json-to-1password.sh ~/Downloads/client_secret_....json
#
# Or store the token as a concealed field and use op run:
# OP_SERVICE_ACCOUNT_TOKEN=op://YOUR_VAULT/CTO Service Account/token
#
# Vault access: in 1Password.com admin, grant this service account "View" + "Create items" on the vault.

OP_SERVICE_ACCOUNT_TOKEN=
