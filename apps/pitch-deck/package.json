{
  "name": "pitch-deck",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3010",
    "build": "next build",
    "start": "next start --port 3010",
    "lint": "eslint",
    "deploy:pages": "npm run build && wrangler pages deploy out --project-name=5dlabs-pitch-deck --branch=main --commit-dirty=true",
    "record:deck": "bash scripts/record-deck-walkthrough.sh",
    "tts:sample": "bash scripts/elevenlabs-tts-sample.sh",
    "tts:walkthrough": "python3 scripts/elevenlabs-walkthrough-full.py",
    "render:pdf": "npx tsx scripts/render-pdf-samples.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.30.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "wrangler": "^4.61.1"
  }
}
