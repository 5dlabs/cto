{
  "name": "cto-chat",
  "displayName": "5dlabs CTO Agents",
  "description": "Dynamic AI agent chat — discovers available agents from the CTO gateway",
  "version": "0.3.0",
  "publisher": "5dlabs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "cto-chat.cto",
        "name": "cto",
        "fullName": "5dlabs CTO",
        "description": "CTO agent — routes to the active harness (OpenClaw, Hermes, etc.)",
        "isSticky": true,
        "isDefault": true
      }
    ],
    "configuration": {
      "title": "CTO Chat",
      "properties": {
        "ctoChat.apiBase": {
          "type": "string",
          "default": "http://localhost:18789",
          "description": "OpenClaw gateway base URL"
        },
        "ctoChat.apiToken": {
          "type": "string",
          "default": "openclaw-internal",
          "description": "Gateway auth token"
        },
        "ctoChat.model": {
          "type": "string",
          "default": "openclaw/coder",
          "description": "Model identifier (openclaw/<agentId>)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^3.0.0"
  }
}
