# =============================================================================
# CLI Integration Test Environment Variables
# =============================================================================
# 
# RECOMMENDED: Use the setup-credentials.sh script to generate this file:
#   ./scripts/setup-credentials.sh bolt   # For Bolt agent
#   ./scripts/setup-credentials.sh rex    # For Rex/Morgan agent
#
# The script fetches credentials from 1Password and writes them here.
#
# MANUAL: If you need to set up manually:
#   op read "op://Automation/Linear Morgan OAuth/developer_token"
#   op read "op://Automation/2lljrd76lwjqcc6f5zogubj3zm/credential"  # Anthropic
#   op read "op://Automation/GitHub-App-Bolt/app-id"
#   op read "op://Automation/GitHub-App-Bolt/private-key"
# =============================================================================

# Linear Integration
LINEAR_OAUTH_TOKEN=your_linear_oauth_token_here
LINEAR_ISSUE_IDENTIFIER=CTOPA-XXXX

# API Keys (only needed for CLIs you're testing)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here

# GitHub App Credentials (for Bolt/other agents needing GitHub access)
GITHUB_APP_ID=your_app_id_here
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_PRIVATE_KEY_B64=base64_encoded_private_key_here
