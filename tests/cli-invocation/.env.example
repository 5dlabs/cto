# =============================================================================
# CLI Integration Test Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Get secrets from 1Password:
#   op read "op://Automation/Linear Morgan OAuth/developer_token"
#   op read "op://Automation/cto-secrets/anthropic_api_key"
# =============================================================================

# Linear Integration (Required)
# OAuth token for Linear API
LINEAR_OAUTH_TOKEN=your_linear_oauth_token_here

# Issue identifier (e.g., CTOPA-123) - activities appear on this issue
LINEAR_ISSUE_IDENTIFIER=CTOPA-XXXX

# Linear Session (Optional - auto-created if not provided)
# If you have an existing session, provide these:
# LINEAR_SESSION_ID=your_session_id
# LINEAR_ISSUE_ID=your_issue_id
# LINEAR_TEAM_ID=your_team_id

# API Keys (only needed for CLIs you're testing)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here
FACTORY_API_KEY=your_factory_api_key_here

# GitHub (for agent git operations)
# GITHUB_TOKEN=your_github_token_here
