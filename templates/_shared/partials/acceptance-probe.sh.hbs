# =========================================================================
# Acceptance Criteria Verification Probe
# =========================================================================

ACCEPTANCE_FILE="${CLI_WORK_DIR}/task/acceptance-criteria.md"
PROBE_RESULT_FILE="${CLAUDE_WORK_DIR:-/tmp}/.acceptance_result"
JUDGE_DECISION_FILE="${JUDGE_DECISION_FILE:-${CLAUDE_WORK_DIR:-/tmp}/.judge_decision}"

# Initialize probe result
echo "pending" > "$PROBE_RESULT_FILE"

probe_acceptance_criteria() {
    echo ""
    echo "════════════════════════════════════════════════════════════════"
    echo "║ Acceptance Criteria Verification"
    echo "════════════════════════════════════════════════════════════════"
    echo ""

    if [ ! -f "$ACCEPTANCE_FILE" ]; then
        echo "⚠️ No acceptance-criteria.md found - skipping verification"
        echo "skipped" > "$PROBE_RESULT_FILE"
        return 0
    fi

    echo "📋 Checking acceptance criteria from: $ACCEPTANCE_FILE"

    # Count total criteria (lines starting with "- [ ]" or "- [x]")
    TOTAL_CRITERIA=$(grep -cE '^\s*-\s*\[([ x])\]' "$ACCEPTANCE_FILE" 2>/dev/null) || TOTAL_CRITERIA=0
    COMPLETED_CRITERIA=$(grep -cE '^\s*-\s*\[x\]' "$ACCEPTANCE_FILE" 2>/dev/null) || COMPLETED_CRITERIA=0

    if [ "$TOTAL_CRITERIA" -eq 0 ]; then
        echo "⚠️ No checkable criteria found in acceptance file"
        echo "skipped" > "$PROBE_RESULT_FILE"
        return 0
    fi

    COMPLETION_PCT=$((COMPLETED_CRITERIA * 100 / TOTAL_CRITERIA))

    echo "  ✓ Completed: $COMPLETED_CRITERIA / $TOTAL_CRITERIA ($COMPLETION_PCT%)"
    echo ""

    # Show uncompleted criteria
    if [ "$COMPLETED_CRITERIA" -lt "$TOTAL_CRITERIA" ]; then
        echo "📝 Remaining criteria:"
        grep -E '^\s*-\s*\[ \]' "$ACCEPTANCE_FILE" | head -10 | while read -r line; do
            echo "  $line"
        done
        REMAINING=$((TOTAL_CRITERIA - COMPLETED_CRITERIA))
        if [ "$REMAINING" -gt 10 ]; then
            echo "  ... and $((REMAINING - 10)) more"
        fi
        echo ""
    fi

    # Determine pass/fail
    # Consider success if >= 90% complete (configurable via env)
    ACCEPTANCE_THRESHOLD="${ACCEPTANCE_THRESHOLD:-90}"
    
    if [ "$COMPLETION_PCT" -ge "$ACCEPTANCE_THRESHOLD" ]; then
        echo "✅ Acceptance criteria met ($COMPLETION_PCT% >= ${ACCEPTANCE_THRESHOLD}% threshold)"
        echo "passed" > "$PROBE_RESULT_FILE"
        return 0
    else
        echo "❌ Acceptance criteria NOT met ($COMPLETION_PCT% < ${ACCEPTANCE_THRESHOLD}% threshold)"
        echo "failed" > "$PROBE_RESULT_FILE"
        return 1
    fi
}

# =========================================================================
# Judge Decision Integration (US-001)
# =========================================================================

# Read the judge decision file if it exists
read_judge_decision() {
    if [ -f "$JUDGE_DECISION_FILE" ]; then
        cat "$JUDGE_DECISION_FILE"
    else
        echo '{"decision": "continue"}'
    fi
}

# Get the decision type from judge decision
get_judge_decision_type() {
    local decision_json
    decision_json=$(read_judge_decision)
    echo "$decision_json" | jq -r '.decision // "continue"' 2>/dev/null || echo "continue"
}

# Check if judge says fresh start is needed
judge_needs_fresh_start() {
    local decision
    decision=$(get_judge_decision_type)
    [ "$decision" = "fresh_start" ]
}

# Check if judge says task is complete
judge_says_complete() {
    local decision
    decision=$(get_judge_decision_type)
    [ "$decision" = "complete" ]
}

# Log judge decision for observability
log_judge_decision() {
    local decision_json
    decision_json=$(read_judge_decision)
    
    echo ""
    echo "════════════════════════════════════════════════════════════════"
    echo "║ Judge Decision"
    echo "════════════════════════════════════════════════════════════════"
    echo ""
    
    local decision reasoning
    decision=$(echo "$decision_json" | jq -r '.decision // "unknown"' 2>/dev/null)
    reasoning=$(echo "$decision_json" | jq -r '.reasoning // "No reasoning provided"' 2>/dev/null)
    
    case "$decision" in
        "complete")
            echo "✅ Judge Decision: COMPLETE"
            ;;
        "fresh_start")
            echo "🔄 Judge Decision: FRESH START"
            ;;
        "continue")
            echo "🔁 Judge Decision: CONTINUE"
            ;;
        *)
            echo "❓ Judge Decision: UNKNOWN ($decision)"
            ;;
    esac
    
    echo "   Reasoning: $reasoning"
    echo ""
}

# Export for use in other partials
export -f probe_acceptance_criteria 2>/dev/null || true
export -f read_judge_decision 2>/dev/null || true
export -f get_judge_decision_type 2>/dev/null || true
export -f judge_needs_fresh_start 2>/dev/null || true
export -f judge_says_complete 2>/dev/null || true
export -f log_judge_decision 2>/dev/null || true

