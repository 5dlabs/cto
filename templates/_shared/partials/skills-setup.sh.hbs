# =========================================================================
# Skills Setup - Write skills inline (content embedded at render time)
#
# Usage:
#   \{\{> skills-setup skills_target="$CLAUDE_WORK_DIR/.claude/skills" skills_label="Claude Code" \}\}
#
# Required context variables:
#   - skills: array of {name, content} objects (content embedded by controller at render time)
#
# Required partial params:
#   - skills_target: destination directory (string, may include env vars like $CLAUDE_WORK_DIR)
#
# Optional partial params:
#   - skills_label: friendly label for logs
# =========================================================================

{{#if skills}}
echo "═══════════════════════════════════════════════════════════════"
echo "║               SKILLS SETUP                                   ║"
echo "═══════════════════════════════════════════════════════════════"

SKILLS_TARGET="{{skills_target}}"

echo "Setting up {{#if skills_label}}{{skills_label}}{{else}}agent{{/if}} skills..."
echo "  ✓ Target: $SKILLS_TARGET"

mkdir -p "$SKILLS_TARGET"

LOADED_SKILLS=""
SKILLS_LOADED_COUNT=0

{{#each skills}}
{{#if this.content}}
mkdir -p "$SKILLS_TARGET/{{this.name}}"
cat > "$SKILLS_TARGET/{{this.name}}/SKILL.md" << 'OPENCLAW_SKILL_EOF_{{@index}}'
{{this.content}}
OPENCLAW_SKILL_EOF_{{@index}}
echo "  ✓ Loaded skill: {{this.name}}"
LOADED_SKILLS="${LOADED_SKILLS}${LOADED_SKILLS:+ }{{this.name}}"
SKILLS_LOADED_COUNT=$((SKILLS_LOADED_COUNT + 1))
{{else}}
echo "  ⚠️ Skill not found in templates: {{this.name}}"
{{/if}}
{{/each}}

echo ""
echo "📚 Skills summary"
echo "  ✓ Loaded count: $SKILLS_LOADED_COUNT"
if [ "$SKILLS_LOADED_COUNT" -gt 0 ]; then
    echo "  ✓ Loaded list: $LOADED_SKILLS"
fi
echo ""
{{/if}}

