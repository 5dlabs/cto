# =========================================================================
# MCP Tools Configuration
# Copies client-config.json to where the tool server expects it
# Merges project-specific config if available from Linear
# =========================================================================

echo ""
echo "🔧 MCP Tools Configuration:"

# The tool server reads config from MCP_CLIENT_CONFIG env var
# Use CLI_WORK_DIR (set by git-setup) as it's guaranteed writable
TOOLS_CONFIG_DEST="${MCP_CLIENT_CONFIG:-${CLI_WORK_DIR:-/workspace}/client-config.json}"

# Project-specific CTO config location (synced from Linear document)
PROJECT_CONFIG="/config/project/cto-config.json"

if [ -f /task-files/client-config.json ]; then
    cp /task-files/client-config.json "$TOOLS_CONFIG_DEST"
    echo "  ✓ client-config.json → $TOOLS_CONFIG_DEST"
    
    # Check if project-specific config exists and merge if available
    if [ -f "$PROJECT_CONFIG" ] && command -v jq >/dev/null 2>&1; then
        echo "  📦 Project-specific config found: $PROJECT_CONFIG"
        
        # Extract agent tools from project config if matching agent
        if [ -n "${GITHUB_APP:-}" ]; then
            AGENT_KEY=$(echo "$GITHUB_APP" | sed 's/5DLabs-//' | tr '[:upper:]' '[:lower:]')
            
            # Try to extract agent-specific tools from project config
            PROJECT_TOOLS=$(jq -r ".agents.${AGENT_KEY}.tools // empty" "$PROJECT_CONFIG" 2>/dev/null)
            
            if [ -n "$PROJECT_TOOLS" ] && [ "$PROJECT_TOOLS" != "null" ]; then
                echo "  ✓ Merging project config for agent: $AGENT_KEY"
                
                # Merge remote tools (union of both)
                BASE_REMOTE=$(jq -r '.remoteTools // []' "$TOOLS_CONFIG_DEST")
                PROJ_REMOTE=$(jq -r ".agents.${AGENT_KEY}.tools.remote // []" "$PROJECT_CONFIG" 2>/dev/null || echo "[]")
                
                # Create merged config
                jq --argjson proj_remote "$PROJ_REMOTE" \
                   '.remoteTools = (.remoteTools + $proj_remote | unique)' \
                   "$TOOLS_CONFIG_DEST" > "${TOOLS_CONFIG_DEST}.tmp" && \
                mv "${TOOLS_CONFIG_DEST}.tmp" "$TOOLS_CONFIG_DEST"
                
                echo "    └─ Merged project tools for $AGENT_KEY"
            fi
        fi
        
        # Also copy full project config for reference
        cp "$PROJECT_CONFIG" "/workspace/project-cto-config.json" 2>/dev/null || true
        echo "    └─ Project config copied to /workspace/project-cto-config.json"
    fi
    
    # Display configured tools summary
    if command -v jq >/dev/null 2>&1; then
        REMOTE_COUNT=$(jq -r '.remoteTools | length' "$TOOLS_CONFIG_DEST" 2>/dev/null || echo "0")
        LOCAL_COUNT=$(jq -r '.localServers | keys | length' "$TOOLS_CONFIG_DEST" 2>/dev/null || echo "0")
        echo "    └─ Remote tools: $REMOTE_COUNT"
        echo "    └─ Local servers: $LOCAL_COUNT"
        
        # List remote tools if present
        if [ "$REMOTE_COUNT" != "0" ] && [ "$REMOTE_COUNT" != "null" ]; then
            echo "    └─ Remote tools available:"
            jq -r '.remoteTools[]?' "$TOOLS_CONFIG_DEST" 2>/dev/null | while read -r tool; do
                echo "       • $tool"
            done
        fi
    fi
else
    echo "  ⚠️ client-config.json not found in /task-files/"
    echo "     Tool server may have limited functionality"
fi

# Legacy support: also handle tools-config.json if present
if [ -f /task-files/tools-config.json ]; then
    cp /task-files/tools-config.json "$CLI_WORK_DIR/tools-config.json" 2>/dev/null || true
    echo "  ✓ tools-config.json (legacy)"
fi

echo ""

