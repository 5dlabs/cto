{{> header }}

{{> node-env }}

{{> config }}

{{> github-auth }}

# =========================================================================
# MCP Diagnostics - verify tools binary and server connectivity
# =========================================================================
{{> mcp-check }}

# =========================================================================
# Set MCP Config for Intake CLI
# =========================================================================
# The controller generates mcp.json and mounts it to /task-files/mcp.json
# We need to tell the intake CLI where to find it via TASKS_MCP_CONFIG
for mcp_path in "/mcp-config/mcp.json" "/task-files/mcp.json"; do
    if [ -f "$mcp_path" ]; then
        export TASKS_MCP_CONFIG="$mcp_path"
        export MCP_CONFIG_FILE="$mcp_path"
        echo "📋 MCP Config for intake CLI: $TASKS_MCP_CONFIG"
        break
    fi
done

if [ -z "$TASKS_MCP_CONFIG" ]; then
    echo "⚠️ No MCP config found for intake CLI"
    echo "   Intake will run without MCP tools (Firecrawl, Context7, etc.)"
fi

# =========================================================================
# Intake Configuration
# =========================================================================

# Primary: intake-files volume (mounted from INTAKE_CONFIGMAP by controller)
# Fallback: task-files (legacy path, used when INTAKE_CONFIGMAP is not set)
if [ -f "/intake-files/config.json" ]; then
    INTAKE_DIR="/intake-files"
elif [ -f "/task-files/config.json" ]; then
    INTAKE_DIR="/task-files"
    echo "  ⚠️  Using legacy /task-files path (INTAKE_CONFIGMAP not set)"
else
    echo "❌ Configuration file not found at /intake-files/config.json or /task-files/config.json"
    exit 1
fi

CONFIG_FILE="${INTAKE_DIR}/config.json"
PRD_FILE="${INTAKE_DIR}/prd.txt"
ARCH_FILE="${INTAKE_DIR}/architecture.md"

echo "📄 Loading configuration..."
PROJECT_NAME=$(jq -r '.project_name' "$CONFIG_FILE")
LINEAR_SESSION_ID=$(jq -r '.linear_session_id // ""' "$CONFIG_FILE")
LINEAR_ISSUE_ID=$(jq -r '.linear_issue_id // ""' "$CONFIG_FILE")
LINEAR_ISSUE_IDENTIFIER=$(jq -r '.linear_issue_identifier // ""' "$CONFIG_FILE")
LINEAR_TEAM_ID=$(jq -r '.linear_team_id // ""' "$CONFIG_FILE")

# Use REPOSITORY_URL from environment if set, otherwise read from config
# The environment variable takes precedence as it's set by the controller
if [ -z "${REPOSITORY_URL:-}" ]; then
    REPOSITORY_URL=$(jq -r '.repository_url // ""' "$CONFIG_FILE")
fi

# GitHub settings for new repo creation
GITHUB_DEFAULT_ORG="${GITHUB_DEFAULT_ORG:-$(jq -r '.github_default_org // "5dlabs"' "$CONFIG_FILE")}"
GITHUB_VISIBILITY="${GITHUB_VISIBILITY:-$(jq -r '.github_visibility // "private"' "$CONFIG_FILE")}"

# Model configuration
PRIMARY_MODEL=$(jq -r '.primary_model' "$CONFIG_FILE")

# Task generation parameters
NUM_TASKS=$(jq -r '.num_tasks // 15' "$CONFIG_FILE")
EXPAND_TASKS=$(jq -r '.expand_tasks // true' "$CONFIG_FILE")
ANALYZE_COMPLEXITY=$(jq -r '.analyze_complexity // true' "$CONFIG_FILE")

echo "  ✓ Project: $PROJECT_NAME"
echo "  ✓ Repository: ${REPOSITORY_URL:-<will create>}"
echo "  ✓ Model: $PRIMARY_MODEL"
echo "  ✓ Tasks: ~$NUM_TASKS"
if [ -n "$LINEAR_SESSION_ID" ] && [ -n "$LINEAR_ISSUE_ID" ] && [ -n "$LINEAR_TEAM_ID" ]; then
    echo "  ✓ Linear session/issue/team metadata detected"
else
    echo "  ⚠️  Linear metadata missing in config.json (intake metadata block may be incomplete)"
fi

# =========================================================================
# GitHub Repository Setup (Create if needed)
# =========================================================================
# This logic was previously in github_prep.sh (Argo step). Now integrated
# directly so all progress is logged via Linear sidecar.

# Normalize repo name from project name (used for new repo creation)
REPO_NAME=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | sed 's/--*/-/g' | sed 's/^-*//;s/-*$//')

# Track whether we created a new repo (affects directory structure)
REPO_CREATED="false"

if [ -z "${REPOSITORY_URL:-}" ] || [ "${REPOSITORY_URL:-}" = "null" ]; then
    # =========================================================================
    # Create New Repository
    # =========================================================================
    echo ""
    echo "🆕 No repository provided - creating new repository..."
    
    FULL_REPO_NAME="${GITHUB_DEFAULT_ORG}/${REPO_NAME}"
    
    # Check if repo already exists
    if gh repo view "$FULL_REPO_NAME" &>/dev/null; then
        echo "  ⚠️ Repository $FULL_REPO_NAME already exists, using it"
        REPOSITORY_URL="https://github.com/${FULL_REPO_NAME}"
    else
        REPO_CREATED="true"
        echo "  → Creating $GITHUB_VISIBILITY repository: $FULL_REPO_NAME"
        if ! gh repo create "$FULL_REPO_NAME" \
            --"$GITHUB_VISIBILITY" \
            --description "Generated from Linear intake: $PROJECT_NAME"; then
            echo "❌ Failed to create repository"
            exit 1
        fi
        
        REPOSITORY_URL="https://github.com/${FULL_REPO_NAME}"
        echo "  ✅ Created repository: $REPOSITORY_URL"
        
        # Initialize with README (cloning may fail for empty repo)
        INIT_DIR="/tmp/repo-init-$(date +%s)"
        mkdir -p "$INIT_DIR"
        cd "$INIT_DIR"
        git init
        git config user.name "Morgan Intake"
        git config user.email "morgan@5dlabs.com"
        
        echo "# $PROJECT_NAME" > README.md
        echo "" >> README.md
        echo "Generated by CTO Agent intake workflow." >> README.md
        
        git add README.md
        git commit -m "chore: initial commit"
        git branch -M main
        git remote add origin "$REPOSITORY_URL"
        git push -u origin main
        echo "  ✅ Initialized repository with README"
        cd /
        rm -rf "$INIT_DIR"
    fi
else
    # =========================================================================
    # Validate Existing Repository
    # =========================================================================
    echo ""
    echo "📂 Using existing repository: $REPOSITORY_URL"
    
    # Extract repo path and verify access
    REPO_PATH=$(echo "$REPOSITORY_URL" | sed 's|https://github.com/||' | sed 's|\.git$||')
    if ! gh repo view "$REPO_PATH" &>/dev/null; then
        echo "❌ Cannot access repository: $REPOSITORY_URL"
        echo "  Please check that the GitHub App has access to this repository."
        exit 1
    fi
    echo "  ✅ Repository accessible"
fi

# =========================================================================
# GitHub Webhook Setup (for PR merge notifications)
# =========================================================================
# Create or update webhook to notify PM server when intake PR is merged

WEBHOOK_CALLBACK_URL="${WEBHOOK_CALLBACK_URL:-}"

if [ -n "$WEBHOOK_CALLBACK_URL" ]; then
    echo ""
    echo "🔗 Setting up GitHub webhook..."
    
    # Extract repo path for API calls
    REPO_PATH=$(echo "$REPOSITORY_URL" | sed 's|https://github.com/||' | sed 's|\.git$||')
    
    # Check if webhook already exists
    EXISTING_WEBHOOK=$(gh api "repos/${REPO_PATH}/hooks" --jq ".[] | select(.config.url == \"${WEBHOOK_CALLBACK_URL}\") | .id" 2>/dev/null || echo "")
    
    if [ -n "$EXISTING_WEBHOOK" ]; then
        echo "  ℹ️  Webhook already exists (ID: $EXISTING_WEBHOOK), updating..."
        # Update existing webhook to ensure correct events
        # Note: gh api -F (--field) flag syntax:
        #   -F key=value      → string value
        #   -F key:=true      → raw JSON (boolean/number/null)
        #   -F 'key[]=value'  → array element (quote to prevent shell glob expansion)
        #   -F 'obj[key]=val' → nested object property
        gh api "repos/${REPO_PATH}/hooks/${EXISTING_WEBHOOK}" \
            --method PATCH \
            -F active:=true \
            -F 'events[]=pull_request' \
            -F "config[url]=${WEBHOOK_CALLBACK_URL}" \
            -F 'config[content_type]=json' \
            --silent && echo "  ✅ Webhook updated" || echo "  ⚠️  Failed to update webhook (non-critical)"
    else
        echo "  → Creating webhook for PR notifications..."
        # Create new webhook
        # Note: gh api -F (--field) flag syntax:
        #   -F key=value      → string value
        #   -F key:=true      → raw JSON (boolean/number/null)
        #   -F 'key[]=value'  → array element (quote to prevent shell glob expansion)
        #   -F 'obj[key]=val' → nested object property
        gh api "repos/${REPO_PATH}/hooks" \
            --method POST \
            -F name=web \
            -F active:=true \
            -F 'events[]=pull_request' \
            -F "config[url]=${WEBHOOK_CALLBACK_URL}" \
            -F 'config[content_type]=json' \
            -F 'config[insecure_ssl]:=0' \
            --silent && echo "  ✅ Webhook created: $WEBHOOK_CALLBACK_URL" || echo "  ⚠️  Failed to create webhook (non-critical)"
    fi
else
    echo ""
    echo "ℹ️  No WEBHOOK_CALLBACK_URL configured, skipping webhook setup"
    echo "   (Set WEBHOOK_CALLBACK_URL to enable automatic play workflow triggers)"
fi

# =========================================================================
# Repository Clone
# =========================================================================

echo ""
echo "📦 Cloning repository..."

CLONE_DIR="/tmp/repo-$(date +%s)"
git clone "$REPOSITORY_URL" "$CLONE_DIR" || exit 1
cd "$CLONE_DIR" || exit 1

git config user.name "Morgan Intake"
git config user.email "morgan@5dlabs.com"

# Determine working directory based on whether we created the repo
# - New repos: work in root (single-project repo)
# - Existing repos: create subdirectory (multi-project support)
PROJECT_DIR_NAME=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | sed 's/--*/-/g' | sed 's/^-*//;s/-*$//')
if [ "$REPO_CREATED" = "true" ]; then
    # New repo - work in root, no subdirectory needed
    PROJECT_DIR="$CLONE_DIR"
    echo "  ℹ️  New repository - working in repo root"
else
    # Existing repo - create project subdirectory
    PROJECT_DIR="$CLONE_DIR/$PROJECT_DIR_NAME"
    mkdir -p "$PROJECT_DIR"
    echo "  ℹ️  Existing repository - using subdirectory: $PROJECT_DIR_NAME"
fi
cd "$PROJECT_DIR" || exit 1

# =========================================================================
# Prepare Input Files
# =========================================================================

echo ""
echo "📝 Setting up input files..."

mkdir -p .tasks/docs
cp "$PRD_FILE" ".tasks/docs/prd.txt"
[ -f "$ARCH_FILE" ] && [ -s "$ARCH_FILE" ] && cp "$ARCH_FILE" ".tasks/docs/architecture.md"

# =========================================================================
# Run Intake CLI (Rust binary for task generation)
# =========================================================================

echo ""
echo "🚀 Running intake workflow..."

# Clean workspace subdir to prevent stale artifacts from previous retries
if [ -d "${WORKSPACE_DIR}" ]; then
    echo "  🧹 Cleaning previous workspace at ${WORKSPACE_DIR}"
    chmod -R 777 "${WORKSPACE_DIR}" 2>/dev/null || true
    rm -rf "${WORKSPACE_DIR}" 2>/dev/null || {
        find "${WORKSPACE_DIR}" -mindepth 1 -delete 2>/dev/null || true
    }
fi
mkdir -p "${WORKSPACE_DIR}"

# Stream output file for sidecar to parse (structured activities)
STREAM_OUTPUT="/workspace/claude-stream.jsonl"
rm -f "$STREAM_OUTPUT" 2>/dev/null || true
touch "$STREAM_OUTPUT"
chmod 666 "$STREAM_OUTPUT" || true

# Agent log file for sidecar to stream to Linear
AGENT_LOG="${LOG_FILE_PATH:-/workspace/agent.log}"
rm -f "$AGENT_LOG" 2>/dev/null || true
touch "$AGENT_LOG"
chmod 666 "$AGENT_LOG" || true

echo "  ✓ Stream output: $STREAM_OUTPUT"
echo "  ✓ Agent log: $AGENT_LOG"

# Check for intake CLI binary
if command -v intake >/dev/null 2>&1; then
    echo "  ✅ intake CLI found: $(which intake)"
    intake --version 2>&1 || true
else
    echo "  ❌ intake CLI not found in PATH"
    echo "  Available binaries in /usr/local/bin:"
    ls -la /usr/local/bin/ 2>/dev/null | head -20
    exit 1
fi

# Build intake CLI arguments
INTAKE_ARGS="--prd .tasks/docs/prd.txt"
INTAKE_ARGS="$INTAKE_ARGS --num-tasks $NUM_TASKS"

# Use CLI mode instead of API mode for AI operations
# This uses the external CLI (claude, codex, etc.) instead of direct API calls
INTAKE_ARGS="$INTAKE_ARGS --use-cli"

# Add architecture if available
if [ -f ".tasks/docs/architecture.md" ] && [ -s ".tasks/docs/architecture.md" ]; then
    INTAKE_ARGS="$INTAKE_ARGS --architecture .tasks/docs/architecture.md"
    echo "  ✓ Architecture document: .tasks/docs/architecture.md"
fi

# Skip expansion/analysis for faster initial generation (can be done later)
if [ "${EXPAND_TASKS:-true}" = "false" ]; then
    INTAKE_ARGS="$INTAKE_ARGS --no-expand"
fi
if [ "${ANALYZE_COMPLEXITY:-true}" = "false" ]; then
    INTAKE_ARGS="$INTAKE_ARGS --no-analyze"
fi

# Set model if specified
if [ -n "$PRIMARY_MODEL" ] && [ "$PRIMARY_MODEL" != "null" ]; then
    INTAKE_ARGS="$INTAKE_ARGS --model $PRIMARY_MODEL"
fi

# Ensure fresh task generation — remove any partial tasks.json from previous attempts
if [ -f ".tasks/tasks/tasks.json" ]; then
    echo "  🔄 Removing stale tasks.json from previous attempt"
    mv ".tasks/tasks/tasks.json" ".tasks/tasks/tasks.json.bak.$(date +%s)"
fi

# =========================================================================
# Deliberation (optional) — Optimist vs Pessimist debate before task gen
# =========================================================================
DELIBERATE=$(jq -r '.deliberate // false' "$CONFIG_FILE")
if [ "$DELIBERATE" = "true" ] && command -v intake-agent >/dev/null 2>&1; then
    echo ""
    echo "🎙️ Running deliberation — Optimist vs Pessimist..."
    PRD_CONTENT=$(cat "$PRD_FILE")
    ARCH_CONTENT=""
    [ -f "$ARCH_FILE" ] && ARCH_CONTENT=$(cat "$ARCH_FILE")
    DELIBERATION_OUTPUT=$(jq -n \
        --arg prd "$PRD_CONTENT" \
        --arg arch "$ARCH_CONTENT" \
        --arg session "${PROJECT_NAME}-$(date +%s)" \
        '{ \
            "operation": "deliberate", \
            "model": "claude-sonnet-4-20250514", \
            "payload": { \
                "prd_content": ($prd + (if $arch != "" then "\n\n## Architecture\n" + $arch else "" end)), \
                "session_id": $session, \
                "timebox_minutes": 10, \
                "research_enabled": true, \
                "research_timeout_minutes": 5 \
            } \
        }' | NATS_URL="${NATS_URL:-nats://nats.messaging.svc.cluster.local:4222}" intake-agent 2>&1)
    DESIGN_BRIEF=$(echo "$DELIBERATION_OUTPUT" | jq -r '.data.design_brief // ""' 2>/dev/null)
    if [ -n "$DESIGN_BRIEF" ] && [ "$DESIGN_BRIEF" != "null" ]; then
        echo "$DESIGN_BRIEF" > ".tasks/docs/design-brief.md"
        echo "  ✅ Design brief generated ($(wc -l < .tasks/docs/design-brief.md) lines)"
        # Use design brief as PRD for task generation
        echo "$DESIGN_BRIEF" > /tmp/design-brief-for-intake.txt
        INTAKE_ARGS="$INTAKE_ARGS --prd /tmp/design-brief-for-intake.txt"
    else
        echo "  ⚠️ Deliberation returned no design brief — proceeding with raw PRD"
    fi
else
    echo "  ℹ️ Deliberation skipped (deliberate=false or intake-agent not found)"
fi

echo ""
echo "📋 Running: intake intake $INTAKE_ARGS"
echo ""

# Run intake CLI and capture output
# shellcheck disable=SC2086
intake intake $INTAKE_ARGS 2>&1 | tee -a "$AGENT_LOG"
INTAKE_EXIT_CODE=${PIPESTATUS[0]}

if [ $INTAKE_EXIT_CODE -ne 0 ]; then
    echo "  ❌ intake CLI failed with exit code $INTAKE_EXIT_CODE"
    exit $INTAKE_EXIT_CODE
fi

echo ""
echo "  ✅ intake CLI completed successfully"

# Verify tasks.json was created
if [ -f ".tasks/tasks/tasks.json" ]; then
    TASK_COUNT=$(jq '.tasks | length' .tasks/tasks/tasks.json 2>/dev/null || echo "0")
    echo "  ✅ Generated $TASK_COUNT tasks in .tasks/tasks/tasks.json"
else
    echo "  ❌ tasks.json was not created"
    echo "  Contents of .tasks/:"
    find .tasks/ -type f 2>/dev/null | head -20
    exit 1
fi

# =========================================================================
# Optional: AI Enhancement Pass (Claude for research/enrichment)
# =========================================================================

INTAKE_CLI="${INTAKE_CLI:-intake}"
echo ""
echo "  ℹ️  CLI mode: $INTAKE_CLI"

# If INTAKE_CLI is set to claude, run an enhancement pass
if [ "$INTAKE_CLI" = "claude" ]; then
    echo ""
    echo "🔬 Running AI enhancement pass with Claude..."
    
    # Build MCP arguments if config available
    MCP_ARGS=""
    if [ -n "$MCP_CONFIG_FILE" ] && [ -f "$MCP_CONFIG_FILE" ]; then
        if command -v jq >/dev/null 2>&1 && jq empty "$MCP_CONFIG_FILE" 2>/dev/null; then
            echo "  ✅ Using MCP configuration: $MCP_CONFIG_FILE"
            # Use --strict-mcp-config to only use servers from our config
            MCP_ARGS="--mcp-config $MCP_CONFIG_FILE --strict-mcp-config"
        fi
    fi
    
    TASKS_JSON=$(cat .tasks/tasks/tasks.json)
    
    PROMPT="You are Morgan, a project management AI agent. The intake CLI has generated an initial task breakdown. Your job is to ENHANCE these tasks with research and additional context.

## Generated Tasks
\`\`\`json
$TASKS_JSON
\`\`\`

## Instructions
1. Review the generated tasks for completeness
2. Use MCP tools to research and enrich task details:
   - Firecrawl: Scrape any URLs mentioned in the PRD for context
   - Context7: Look up documentation for mentioned technologies
3. Update .tasks/tasks/tasks.json with enhanced details
4. Do NOT change task structure or dependencies, only add details
5. Complete your work - do NOT ask questions or wait for input

Focus on adding implementation hints, technology references, and testing strategies.
"

    CLAUDE_CMD="claude -p \"$PROMPT\" --dangerously-skip-permissions --output-format stream-json --verbose $MCP_ARGS"
    
    if command -v script >/dev/null 2>&1; then
        echo "  ✓ Using script for unbuffered output"
        # shellcheck disable=SC2086
        script -q -c "$CLAUDE_CMD" /dev/null | tee "$STREAM_OUTPUT" "$AGENT_LOG" || echo "  ⚠️ Claude enhancement pass had issues (non-fatal)"
    else
        # shellcheck disable=SC2086
        eval "$CLAUDE_CMD" | tee "$STREAM_OUTPUT" "$AGENT_LOG" || echo "  ⚠️ Claude enhancement pass had issues (non-fatal)"
    fi
    
    echo "  ✅ AI enhancement pass completed"
fi

# Tasks already verified above after intake CLI run
TASKS_FILE=".tasks/tasks/tasks.json"

# =========================================================================
# Session 2: Prompt Generation
# =========================================================================
# Split tasks.json into individual task files for bounded-context processing
echo ""
echo "📝 Session 2: Generating per-task prompts..."

# First, split tasks.json into individual task-N.json files
echo "  → Splitting tasks.json into individual task files..."
intake split-tasks --input "$TASKS_FILE" --output .tasks/tasks 2>&1 || {
    echo "⚠️ Task splitting failed, falling back to template-based docs"
    intake generate-docs --output .tasks/docs 2>&1 || echo "⚠️ Doc generation also failed"
}

# Check if we should run AI-based prompt generation
GENERATE_AI_PROMPTS="${GENERATE_AI_PROMPTS:-true}"
if [ "$GENERATE_AI_PROMPTS" = "true" ]; then
    echo "  → Running AI-based prompt generation (Session 2)..."
    # Build MCP args for prompt generation
    PROMPT_MCP_ARGS=""
    if [ -n "$MCP_CONFIG_FILE" ] && [ -f "$MCP_CONFIG_FILE" ]; then
        PROMPT_MCP_ARGS="--mcp-config $MCP_CONFIG_FILE"
    fi
    
    # Run prompt generation for all tasks
    # shellcheck disable=SC2086
    intake generate-prompts \
        --all \
        --tasks-dir .tasks/tasks \
        --output .tasks/docs \
        --cli "$INTAKE_CLI" \
        --include-prd \
        --include-arch \
        --research \
        $PROMPT_MCP_ARGS 2>&1 || {
            echo "⚠️ AI prompt generation failed, falling back to template-based docs"
            intake generate-docs --output .tasks/docs 2>&1 || echo "⚠️ Template doc generation also failed"
        }
else
    # Use template-based generation (faster, no additional AI cost)
    echo "  → Using template-based documentation (set GENERATE_AI_PROMPTS=false to skip AI prompts)..."
    intake generate-docs --output .tasks/docs 2>&1 || echo "⚠️ Doc generation failed"
fi

echo "✅ Per-task documentation generated"

# =========================================================================
# Create Pull Request
# =========================================================================

echo ""
echo "🔀 Creating Pull Request..."

cd "$CLONE_DIR" || exit 1

# Detect the repository's default branch for PR base
if [ -z "${PR_BASE_BRANCH:-}" ]; then
  # Try to detect from remote HEAD
  DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
  if [ -n "$DEFAULT_BRANCH" ] && git show-ref --verify --quiet "refs/remotes/origin/$DEFAULT_BRANCH"; then
    PR_BASE_BRANCH="$DEFAULT_BRANCH"
  elif git show-ref --verify --quiet "refs/remotes/origin/develop"; then
    PR_BASE_BRANCH="develop"
  elif git show-ref --verify --quiet "refs/remotes/origin/main"; then
    PR_BASE_BRANCH="main"
  elif git show-ref --verify --quiet "refs/remotes/origin/master"; then
    PR_BASE_BRANCH="master"
  else
    PR_BASE_BRANCH="main"
  fi
  echo "  ℹ️  Detected base branch: $PR_BASE_BRANCH"
fi

PROJECT_DIR_METADATA=""
if [ "$REPO_CREATED" != "true" ]; then
    PROJECT_DIR_METADATA="$PROJECT_DIR_NAME"
fi

INTAKE_METADATA=$(jq -c -n \
    --arg session_id "$LINEAR_SESSION_ID" \
    --arg prd_issue_id "$LINEAR_ISSUE_ID" \
    --arg prd_identifier "$LINEAR_ISSUE_IDENTIFIER" \
    --arg team_id "$LINEAR_TEAM_ID" \
    --arg project_name "$PROJECT_NAME" \
    --arg project_dir "$PROJECT_DIR_METADATA" \
    '{
        session_id: $session_id,
        prd_issue_id: $prd_issue_id,
        prd_identifier: $prd_identifier,
        team_id: $team_id
     }
     + (if $project_name != "" and $project_name != "null" then {project_name: $project_name} else {} end)
     + (if $project_dir != "" and $project_dir != "null" then {project_dir: $project_dir} else {} end)')

BRANCH_NAME="intake-${PROJECT_DIR_NAME}-$(date +%Y%m%d-%H%M%S)"
git checkout -b "$BRANCH_NAME"
git add -A
git commit -m "feat: intake for $PROJECT_NAME

- Session 1: $TASK_COUNT tasks generated (tasks.json)
- Session 2: Per-task prompts (prompt.md, prompt.xml, acceptance.md)
- Agent routing hints applied
- AI prompts: $GENERATE_AI_PROMPTS

🤖 Generated by Morgan (two-session intake)"

git push -u origin "$BRANCH_NAME"

gh pr create \
    --title "🚀 Intake: $PROJECT_NAME" \
    --body "## Intake: $PROJECT_NAME

### Two-Session Workflow
- **Session 1**: Task planning (PRD → tasks.json)
- **Session 2**: Prompt generation (tasks → per-task prompts)

### Generated Structure
\`\`\`
$PROJECT_DIR_NAME/
├── .tasks/
│   ├── docs/
│   │   ├── prd.txt
│   │   ├── architecture.md (if provided)
│   │   └── task-*/           # Per-task prompts
│   │       ├── prompt.xml
│   │       ├── prompt.md
│   │       └── acceptance.md
│   └── tasks/
│       ├── tasks.json        # Session 1: AI-generated task breakdown
│       └── task-*.json       # Individual task files for Session 2
\`\`\`

### Stats
- **Tasks**: $TASK_COUNT
- **Model**: $PRIMARY_MODEL
- **AI Prompts**: $GENERATE_AI_PROMPTS

<!-- intake-metadata: $INTAKE_METADATA -->

🤖 Generated by Morgan (two-session intake)" \
    --head "$BRANCH_NAME" \
    --base "$PR_BASE_BRANCH" || echo "⚠️ PR creation failed, branch pushed: $BRANCH_NAME"

{{> completion }}

