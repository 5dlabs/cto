{{> header }}

{{> node-env }}

{{> config }}

{{> github-auth }}

# =========================================================================
# MCP Diagnostics - verify tools binary and server connectivity
# =========================================================================
{{> mcp-check }}

# =========================================================================
# Set MCP Config for Intake CLI
# =========================================================================
# The controller generates mcp.json and mounts it to /task-files/mcp.json
# We need to tell the intake CLI where to find it via TASKS_MCP_CONFIG
for mcp_path in "/mcp-config/mcp.json" "/task-files/mcp.json"; do
    if [ -f "$mcp_path" ]; then
        export TASKS_MCP_CONFIG="$mcp_path"
        export MCP_CONFIG_FILE="$mcp_path"
        echo "📋 MCP Config for intake CLI: $TASKS_MCP_CONFIG"
        break
    fi
done

if [ -z "$TASKS_MCP_CONFIG" ]; then
    echo "⚠️ No MCP config found for intake CLI"
    echo "   Intake will run without MCP tools (Firecrawl, Context7, etc.)"
fi

# =========================================================================
# Intake Configuration
# =========================================================================

# Primary: intake-files volume (mounted from INTAKE_CONFIGMAP by controller)
# Fallback: task-files (legacy path, used when INTAKE_CONFIGMAP is not set)
if [ -f "/intake-files/config.json" ]; then
    INTAKE_DIR="/intake-files"
elif [ -f "/task-files/config.json" ]; then
    INTAKE_DIR="/task-files"
    echo "  ⚠️  Using legacy /task-files path (INTAKE_CONFIGMAP not set)"
else
    echo "❌ Configuration file not found at /intake-files/config.json or /task-files/config.json"
    exit 1
fi

CONFIG_FILE="${INTAKE_DIR}/config.json"
PRD_FILE="${INTAKE_DIR}/prd.txt"
ARCH_FILE="${INTAKE_DIR}/architecture.md"

echo "📄 Loading configuration..."
PROJECT_NAME=$(jq -r '.project_name' "$CONFIG_FILE")
LINEAR_SESSION_ID=$(jq -r '.linear_session_id // ""' "$CONFIG_FILE")
LINEAR_ISSUE_ID=$(jq -r '.linear_issue_id // ""' "$CONFIG_FILE")
LINEAR_ISSUE_IDENTIFIER=$(jq -r '.linear_issue_identifier // ""' "$CONFIG_FILE")
LINEAR_TEAM_ID=$(jq -r '.linear_team_id // ""' "$CONFIG_FILE")

# Use REPOSITORY_URL from environment if set, otherwise read from config
# The environment variable takes precedence as it's set by the controller
if [ -z "${REPOSITORY_URL:-}" ]; then
    REPOSITORY_URL=$(jq -r '.repository_url // ""' "$CONFIG_FILE")
fi

# GitHub settings for new repo creation
GITHUB_DEFAULT_ORG="${GITHUB_DEFAULT_ORG:-$(jq -r '.github_default_org // "5dlabs"' "$CONFIG_FILE")}"
GITHUB_VISIBILITY="${GITHUB_VISIBILITY:-$(jq -r '.github_visibility // "private"' "$CONFIG_FILE")}"

# Model configuration
PRIMARY_MODEL=$(jq -r '.primary_model' "$CONFIG_FILE")

# Task generation parameters
NUM_TASKS=$(jq -r '.num_tasks // 15' "$CONFIG_FILE")
EXPAND_TASKS=$(jq -r '.expand_tasks // true' "$CONFIG_FILE")
ANALYZE_COMPLEXITY=$(jq -r '.analyze_complexity // true' "$CONFIG_FILE")

echo "  ✓ Project: $PROJECT_NAME"
echo "  ✓ Repository: ${REPOSITORY_URL:-<will create>}"
echo "  ✓ Model: $PRIMARY_MODEL"
echo "  ✓ Tasks: ~$NUM_TASKS"
if [ -n "$LINEAR_SESSION_ID" ] && [ -n "$LINEAR_ISSUE_ID" ] && [ -n "$LINEAR_TEAM_ID" ]; then
    echo "  ✓ Linear session/issue/team metadata detected"
else
    echo "  ⚠️  Linear metadata missing in config.json (intake metadata block may be incomplete)"
fi

# =========================================================================
# GitHub Repository Setup (Create if needed)
# =========================================================================
# This logic was previously in github_prep.sh (Argo step). Now integrated
# directly so all progress is logged via Linear sidecar.

# Normalize repo name from project name (used for new repo creation)
REPO_NAME=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | sed 's/--*/-/g' | sed 's/^-*//;s/-*$//')

# Track whether we created a new repo (affects directory structure)
REPO_CREATED="false"

if [ -z "${REPOSITORY_URL:-}" ] || [ "${REPOSITORY_URL:-}" = "null" ]; then
    # =========================================================================
    # Create New Repository
    # =========================================================================
    echo ""
    echo "🆕 No repository provided - creating new repository..."
    
    FULL_REPO_NAME="${GITHUB_DEFAULT_ORG}/${REPO_NAME}"
    
    # Check if repo already exists
    if gh repo view "$FULL_REPO_NAME" &>/dev/null; then
        echo "  ⚠️ Repository $FULL_REPO_NAME already exists, using it"
        REPOSITORY_URL="https://github.com/${FULL_REPO_NAME}"
    else
        REPO_CREATED="true"
        echo "  → Creating $GITHUB_VISIBILITY repository: $FULL_REPO_NAME"
        if ! gh repo create "$FULL_REPO_NAME" \
            --"$GITHUB_VISIBILITY" \
            --description "Generated from Linear intake: $PROJECT_NAME"; then
            echo "❌ Failed to create repository"
            exit 1
        fi
        
        REPOSITORY_URL="https://github.com/${FULL_REPO_NAME}"
        echo "  ✅ Created repository: $REPOSITORY_URL"
        
        # Initialize with README (cloning may fail for empty repo)
        INIT_DIR="/tmp/repo-init-$(date +%s)"
        mkdir -p "$INIT_DIR"
        cd "$INIT_DIR"
        git init
        git config user.name "Morgan Intake"
        git config user.email "morgan@5dlabs.com"
        
        echo "# $PROJECT_NAME" > README.md
        echo "" >> README.md
        echo "Generated by CTO Agent intake workflow." >> README.md
        
        git add README.md
        git commit -m "chore: initial commit"
        git branch -M main
        git remote add origin "$REPOSITORY_URL"
        git push -u origin main
        echo "  ✅ Initialized repository with README"
        cd /
        rm -rf "$INIT_DIR"
    fi
else
    # =========================================================================
    # Validate Existing Repository
    # =========================================================================
    echo ""
    echo "📂 Using existing repository: $REPOSITORY_URL"
    
    # Extract repo path and verify access
    REPO_PATH=$(echo "$REPOSITORY_URL" | sed 's|https://github.com/||' | sed 's|\.git$||')
    if ! gh repo view "$REPO_PATH" &>/dev/null; then
        echo "❌ Cannot access repository: $REPOSITORY_URL"
        echo "  Please check that the GitHub App has access to this repository."
        exit 1
    fi
    echo "  ✅ Repository accessible"
fi

# =========================================================================
# GitHub Webhook Setup (for PR merge notifications)
# =========================================================================
# Create or update webhook to notify PM server when intake PR is merged

WEBHOOK_CALLBACK_URL="${WEBHOOK_CALLBACK_URL:-}"

if [ -n "$WEBHOOK_CALLBACK_URL" ]; then
    echo ""
    echo "🔗 Setting up GitHub webhook..."
    
    # Extract repo path for API calls
    REPO_PATH=$(echo "$REPOSITORY_URL" | sed 's|https://github.com/||' | sed 's|\.git$||')
    
    # Check if webhook already exists
    EXISTING_WEBHOOK=$(gh api "repos/${REPO_PATH}/hooks" --jq ".[] | select(.config.url == \"${WEBHOOK_CALLBACK_URL}\") | .id" 2>/dev/null || echo "")
    
    if [ -n "$EXISTING_WEBHOOK" ]; then
        echo "  ℹ️  Webhook already exists (ID: $EXISTING_WEBHOOK), updating..."
        # Update existing webhook to ensure correct events
        # Note: gh api -F (--field) flag syntax:
        #   -F key=value      → string value
        #   -F key:=true      → raw JSON (boolean/number/null)
        #   -F 'key[]=value'  → array element (quote to prevent shell glob expansion)
        #   -F 'obj[key]=val' → nested object property
        gh api "repos/${REPO_PATH}/hooks/${EXISTING_WEBHOOK}" \
            --method PATCH \
            -F active:=true \
            -F 'events[]=pull_request' \
            -F "config[url]=${WEBHOOK_CALLBACK_URL}" \
            -F 'config[content_type]=json' \
            --silent && echo "  ✅ Webhook updated" || echo "  ⚠️  Failed to update webhook (non-critical)"
    else
        echo "  → Creating webhook for PR notifications..."
        # Create new webhook
        # Note: gh api -F (--field) flag syntax:
        #   -F key=value      → string value
        #   -F key:=true      → raw JSON (boolean/number/null)
        #   -F 'key[]=value'  → array element (quote to prevent shell glob expansion)
        #   -F 'obj[key]=val' → nested object property
        gh api "repos/${REPO_PATH}/hooks" \
            --method POST \
            -F name=web \
            -F active:=true \
            -F 'events[]=pull_request' \
            -F "config[url]=${WEBHOOK_CALLBACK_URL}" \
            -F 'config[content_type]=json' \
            -F 'config[insecure_ssl]:=0' \
            --silent && echo "  ✅ Webhook created: $WEBHOOK_CALLBACK_URL" || echo "  ⚠️  Failed to create webhook (non-critical)"
    fi
else
    echo ""
    echo "ℹ️  No WEBHOOK_CALLBACK_URL configured, skipping webhook setup"
    echo "   (Set WEBHOOK_CALLBACK_URL to enable automatic play workflow triggers)"
fi

# =========================================================================
# Repository Clone
# =========================================================================

echo ""
echo "📦 Cloning repository..."

CLONE_DIR="/tmp/repo-$(date +%s)"
git clone "$REPOSITORY_URL" "$CLONE_DIR" || exit 1
cd "$CLONE_DIR" || exit 1

git config user.name "Morgan Intake"
git config user.email "morgan@5dlabs.com"

# Determine working directory based on whether we created the repo
# - New repos: work in root (single-project repo)
# - Existing repos: create subdirectory (multi-project support)
PROJECT_DIR_NAME=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | sed 's/--*/-/g' | sed 's/^-*//;s/-*$//')
if [ "$REPO_CREATED" = "true" ]; then
    # New repo - work in root, no subdirectory needed
    PROJECT_DIR="$CLONE_DIR"
    echo "  ℹ️  New repository - working in repo root"
else
    # Existing repo - create project subdirectory
    PROJECT_DIR="$CLONE_DIR/$PROJECT_DIR_NAME"
    mkdir -p "$PROJECT_DIR"
    echo "  ℹ️  Existing repository - using subdirectory: $PROJECT_DIR_NAME"
fi
cd "$PROJECT_DIR" || exit 1

# =========================================================================
# Prepare Input Files
# =========================================================================

echo ""
echo "📝 Setting up input files..."

mkdir -p .tasks/docs
cp "$PRD_FILE" ".tasks/docs/prd.txt"
[ -f "$ARCH_FILE" ] && [ -s "$ARCH_FILE" ] && cp "$ARCH_FILE" ".tasks/docs/architecture.md"

# =========================================================================
# Prepare Workspace
# =========================================================================

echo ""
echo "🚀 Running intake pipeline..."

if [ -d "${WORKSPACE_DIR}" ]; then
    echo "  🧹 Cleaning previous workspace at ${WORKSPACE_DIR}"
    chmod -R 777 "${WORKSPACE_DIR}" 2>/dev/null || true
    rm -rf "${WORKSPACE_DIR}" 2>/dev/null || {
        find "${WORKSPACE_DIR}" -mindepth 1 -delete 2>/dev/null || true
    }
fi
mkdir -p "${WORKSPACE_DIR}"

STREAM_OUTPUT="/workspace/claude-stream.jsonl"
rm -f "$STREAM_OUTPUT" 2>/dev/null || true
touch "$STREAM_OUTPUT"
chmod 666 "$STREAM_OUTPUT" || true

AGENT_LOG="${LOG_FILE_PATH:-/workspace/agent.log}"
rm -f "$AGENT_LOG" 2>/dev/null || true
touch "$AGENT_LOG"
chmod 666 "$AGENT_LOG" || true

echo "  ✓ Stream output: $STREAM_OUTPUT"
echo "  ✓ Agent log: $AGENT_LOG"

# =========================================================================
# Detect base branch for PR
# =========================================================================

cd "$CLONE_DIR" || exit 1

if [ -z "${PR_BASE_BRANCH:-}" ]; then
  DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
  if [ -n "$DEFAULT_BRANCH" ] && git show-ref --verify --quiet "refs/remotes/origin/$DEFAULT_BRANCH"; then
    PR_BASE_BRANCH="$DEFAULT_BRANCH"
  elif git show-ref --verify --quiet "refs/remotes/origin/develop"; then
    PR_BASE_BRANCH="develop"
  elif git show-ref --verify --quiet "refs/remotes/origin/main"; then
    PR_BASE_BRANCH="main"
  elif git show-ref --verify --quiet "refs/remotes/origin/master"; then
    PR_BASE_BRANCH="master"
  else
    PR_BASE_BRANCH="main"
  fi
  echo "  ℹ️  Detected base branch: $PR_BASE_BRANCH"
fi

cd "$PROJECT_DIR" || exit 1

# =========================================================================
# Build Linear metadata for PR body
# =========================================================================

PROJECT_DIR_METADATA=""
if [ "$REPO_CREATED" != "true" ]; then
    PROJECT_DIR_METADATA="$PROJECT_DIR_NAME"
fi

INTAKE_METADATA=$(jq -c -n \
    --arg session_id "$LINEAR_SESSION_ID" \
    --arg prd_issue_id "$LINEAR_ISSUE_ID" \
    --arg prd_identifier "$LINEAR_ISSUE_IDENTIFIER" \
    --arg team_id "$LINEAR_TEAM_ID" \
    --arg project_name "$PROJECT_NAME" \
    --arg project_dir "$PROJECT_DIR_METADATA" \
    '{
        session_id: $session_id,
        prd_issue_id: $prd_issue_id,
        prd_identifier: $prd_identifier,
        team_id: $team_id
     }
     + (if $project_name != "" and $project_name != "null" then {project_name: $project_name} else {} end)
     + (if $project_dir != "" and $project_dir != "null" then {project_dir: $project_dir} else {} end)')

# =========================================================================
# Run Lobster Pipeline (deliberation + intake + PR)
# =========================================================================
# The pipeline.lobster.yaml workflow handles everything:
#   1. Deliberation (if deliberate=true): Tavily research, Optimist/Pessimist
#      debate via NATS, committee voting on decision points, design brief
#   2. Intake: PRD parsing, complexity analysis, task expansion, 5-model
#      quality voting, doc/prompt generation, commit, and PR creation

DELIBERATE=$(jq -r '.deliberate // false' "$CONFIG_FILE")
INCLUDE_CODEBASE=$(jq -r '.include_codebase // false' "$CONFIG_FILE")
PRD_CONTENT=$(cat "$PRD_FILE")
ARCH_CONTENT=""
[ -f "$ARCH_FILE" ] && [ -s "$ARCH_FILE" ] && ARCH_CONTENT=$(cat "$ARCH_FILE")

FULL_PRD_CONTENT="$PRD_CONTENT"
if [ -n "$ARCH_CONTENT" ]; then
    FULL_PRD_CONTENT="${PRD_CONTENT}

## Architecture
${ARCH_CONTENT}"
fi

echo ""
echo "📋 Launching Lobster intake pipeline..."
echo "  ✓ Project: $PROJECT_NAME"
echo "  ✓ Deliberate: $DELIBERATE"
echo "  ✓ Include codebase: $INCLUDE_CODEBASE"
echo "  ✓ Repository: ${REPOSITORY_URL:-<none>}"
echo "  ✓ Num tasks: $NUM_TASKS"
echo "  ✓ Base branch: $PR_BASE_BRANCH"
echo ""

jq -n \
    --arg prd_content "$FULL_PRD_CONTENT" \
    --arg project_name "$PROJECT_NAME" \
    --argjson num_tasks "$NUM_TASKS" \
    --argjson deliberate "$DELIBERATE" \
    --argjson include_codebase "$INCLUDE_CODEBASE" \
    --arg repository_url "${REPOSITORY_URL:-}" \
    --arg intake_metadata "$INTAKE_METADATA" \
    --arg pr_base_branch "$PR_BASE_BRANCH" \
    '{
        "prd_content": $prd_content,
        "project_name": $project_name,
        "num_tasks": $num_tasks,
        "deliberate": $deliberate,
        "include_codebase": $include_codebase,
        "repository_url": $repository_url,
        "intake_metadata": $intake_metadata,
        "pr_base_branch": $pr_base_branch
    }' | openclaw.invoke --workflow pipeline.lobster.yaml 2>&1 | tee -a "$AGENT_LOG"

PIPELINE_EXIT_CODE=${PIPESTATUS[0]}

if [ $PIPELINE_EXIT_CODE -ne 0 ]; then
    echo "  ❌ Lobster pipeline failed with exit code $PIPELINE_EXIT_CODE"
    exit $PIPELINE_EXIT_CODE
fi

echo ""
echo "✅ Intake pipeline completed successfully"

{{> completion }}

