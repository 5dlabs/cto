TOOLSEOF

# HEARTBEAT.md — empty for CRD pods (task-focused, no periodic checks)
cat > /workspace/HEARTBEAT.md <<'HEARTBEATEOF'
# HEARTBEAT.md
# CRD pods are task-focused — no periodic background checks needed.
# Keep this file empty to skip heartbeat API calls.
HEARTBEATEOF

echo "✅ Workspace files written (AGENTS, SOUL, IDENTITY, USER, TOOLS, HEARTBEAT)"

# ─── Step 5: Write BOOT.md (task prompt) ───────────────────────────────
echo "[harness] Step 5: BOOT.md..."
echo "[harness] Agent: {{agent_name}} | Model: {{model}} | CLI: {{cli_type}}"

{{#if prompt_modification}}
cat > /workspace/BOOT.md <<'BOOTEOF'
{{{prompt_modification}}}
BOOTEOF
echo "[harness] BOOT.md written ($(wc -c < /workspace/BOOT.md) bytes)"
{{else}}
echo "[harness] No prompt_modification, skipping BOOT.md"
{{/if}}

# ─── Step 6: Start gateway with completion watcher ─────────────────────
echo "[harness] Starting gateway (BOOT.md will auto-execute)..."

# Start gateway in background
openclaw gateway &
GW_PID=$!
echo "[harness] Gateway PID: $GW_PID"

# Completion watcher: detect boot session finish → write .agent_done → kill gateway
(
  set +e  # Disable errexit in watcher subshell (ls/grep may fail early)
  SESSIONS_DIR="$HOME/.openclaw/agents/main/sessions"
  echo "[watcher] Monitoring for boot session completion..."
  while true; do
    sleep 10
    # Check if gateway is still alive
    if ! kill -0 "$GW_PID" 2>/dev/null; then
      echo "[watcher] Gateway exited on its own"
      exit 0
    fi
    # Look for completed boot session
    BOOT_SESSION="$(find "$SESSIONS_DIR" -name 'boot-*.jsonl' -print -quit 2>/dev/null)"
    if [ -n "$BOOT_SESSION" ]; then
      if grep -q '"stopReason":"stop"' "$BOOT_SESSION" 2>/dev/null || \
         grep -q '"stopReason":"end_turn"' "$BOOT_SESSION" 2>/dev/null; then
        echo "[watcher] ✅ BOOT.md session completed"
        echo "completed" > /workspace/.agent_done
        echo "[watcher] Wrote /workspace/.agent_done"
        sleep 5
        # Graceful shutdown: try CLI stop, then SIGTERM the process
        openclaw gateway stop 2>/dev/null || true
        kill -TERM "$GW_PID" 2>/dev/null || true
        sleep 3
        kill -KILL "$GW_PID" 2>/dev/null || true
        exit 0
      fi
    fi
  done
) &
WATCHER_PID=$!
echo "[harness] Completion watcher PID: $WATCHER_PID"

# Wait for gateway to exit
wait "$GW_PID" 2>/dev/null
EXIT_CODE=$?
kill "$WATCHER_PID" 2>/dev/null || true
echo "[harness] Gateway exited (code=$EXIT_CODE)"
exit $EXIT_CODE
