#!/bin/bash
# =========================================================================
# OpenClaw Harness Agent — CRD Pod Entrypoint
#
# Steps:
#   1. Environment setup (writable HOME, paths)
#   2. GitHub authentication (JWT → installation token)
#   3. Git clone repository to /workspace
#   4. Install OpenClaw config + pre-create state dirs
#   5. Write workspace files (SOUL, IDENTITY, USER, TOOLS, AGENTS, HEARTBEAT)
#   6. Write BOOT.md (task prompt — auto-executes on gateway start)
#   7. Start gateway with completion watcher (.agent_done sentinel)
#
# Template variables:
#   {{agent_name}}, {{agent_name_upper}}, {{cli_type}}, {{model}},
#   {{repository_url}}, {{github_app}}, prompt_modification (if set)
# =========================================================================
set -euo pipefail

# ─── Environment ───────────────────────────────────────────────────────
# Always use a writable HOME — the image's /home/node may be root-owned
export HOME="/tmp/agent-home"
mkdir -p "$HOME"

mkdir -p /tmp/npm-cache
export npm_config_cache=/tmp/npm-cache

for f in /etc/profile.d/*.sh; do
  [ -f "$f" ] && source "$f"
done

# ─── Step 1: GitHub Authentication ─────────────────────────────────────
echo "[harness] Step 1: GitHub authentication..."
GITHUB_APP="{{github_app}}"
GH_HOST="${GH_HOST:-github.com}"

if [ -z "${GITHUB_TOKEN:-}" ] && [ -n "${GITHUB_APP_ID:-}" ] && [ -n "${GITHUB_APP_PRIVATE_KEY:-}" ]; then
  echo "🔐 Generating GitHub token from app credentials..."

  TEMP_KEY="/var/run/secrets/github-app-key/private-key"
  mkdir -p "$(dirname "$TEMP_KEY")"
  echo "$GITHUB_APP_PRIVATE_KEY" | sed 's/\\n/\n/g' > "$TEMP_KEY"
  chmod 600 "$TEMP_KEY"
  export GITHUB_APP_PRIVATE_KEY_FILE="$TEMP_KEY"

  NOW=$(date +%s)
  IAT=$((NOW - 60))
  EXP=$((NOW + 600))

  HEADER=$(echo -n '{"alg":"RS256","typ":"JWT"}' | openssl base64 -e | tr -d '=' | tr '/+' '_-' | tr -d '\n')
  PAYLOAD=$(echo -n "{\"iat\":${IAT},\"exp\":${EXP},\"iss\":\"${GITHUB_APP_ID}\"}" | openssl base64 -e | tr -d '=' | tr '/+' '_-' | tr -d '\n')
  SIGNATURE=$(echo -n "${HEADER}.${PAYLOAD}" | openssl dgst -sha256 -sign "$TEMP_KEY" | openssl base64 -e | tr -d '=' | tr '/+' '_-' | tr -d '\n')
  JWT="${HEADER}.${PAYLOAD}.${SIGNATURE}"

  if [ -n "${GITHUB_APP_INSTALLATION_ID:-}" ]; then
    INSTALLATION_ID="$GITHUB_APP_INSTALLATION_ID"
    echo "📌 Using installation ID from environment: $INSTALLATION_ID"
  else
    INSTALLATIONS=$(curl -sf -H "Authorization: Bearer $JWT" -H "Accept: application/vnd.github+json" "https://api.github.com/app/installations" 2>&1)
    INSTALLATION_ID=$(echo "$INSTALLATIONS" | jq -r '.[0].id')
  fi

  TOKEN_RESPONSE=$(curl -sf -X POST \
    -H "Authorization: Bearer $JWT" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/app/installations/${INSTALLATION_ID}/access_tokens" \
    -d '{"permissions":{"contents":"write","pull_requests":"write","issues":"write","metadata":"read"}}' 2>&1)
  export GITHUB_TOKEN=$(echo "$TOKEN_RESPONSE" | jq -r '.token')

  if [ -n "$GITHUB_TOKEN" ] && [ "$GITHUB_TOKEN" != "null" ]; then
    echo "✅ GitHub token generated (${#GITHUB_TOKEN} chars)"
    git config --global --add safe.directory /workspace
    git config --global credential.helper store
    echo "https://x-access-token:${GITHUB_TOKEN}@github.com" > "$HOME/.git-credentials"
    git config --global user.name "{{agent_name}}-bot[5dlabs]"
    git config --global user.email "{{agent_name}}-bot@5dlabs.io"
    git config --global url."https://x-access-token:${GITHUB_TOKEN}@github.com/".insteadOf "https://github.com/"
  else
    echo "❌ Failed to generate GitHub token"
  fi
else
  echo "⚠️ No GitHub App credentials found, skipping auth"
fi

# ─── Step 2: Git Clone ─────────────────────────────────────────────────
echo "[harness] Step 2: Git clone..."
REPO_URL="{{repository_url}}"
if [ -n "$REPO_URL" ] && [ -n "${GITHUB_TOKEN:-}" ]; then
  cd /workspace
  if [ -d ".git" ]; then
    echo "📂 Workspace already has a git repo, pulling latest..."
    git pull --ff-only 2>&1 || echo "⚠️ Pull failed, continuing with existing"
  else
    echo "📥 Cloning $REPO_URL..."
    git clone "$REPO_URL" /tmp/repo-clone 2>&1
    cp -rn /tmp/repo-clone/. /workspace/ 2>/dev/null || true
    rm -rf /tmp/repo-clone
  fi
  echo "✅ Repository ready in /workspace"
else
  echo "⚠️ No repo URL or token, skipping clone"
fi

# ─── Step 3: Install OpenClaw config ───────────────────────────────────
echo "[harness] Step 3: OpenClaw config + state directories..."

# Pre-create all OpenClaw state directories
mkdir -p "$HOME/.openclaw/credentials"
mkdir -p "$HOME/.openclaw/agents/main/sessions"
mkdir -p "$HOME/.openclaw/canvas"

# Runtime Discord gate: only enable if bot token env var is non-empty
DISCORD_TOKEN_VAR="DISCORD_TOKEN_{{agent_name_upper}}"
DISCORD_CHANNEL_VAR="DISCORD_CHANNEL_{{agent_name_upper}}"
if [ -n "${!DISCORD_TOKEN_VAR:-}" ] && [ -n "${!DISCORD_CHANNEL_VAR:-}" ]; then
  echo "🟢 Discord token + channel found for {{agent_name}}"
  DISCORD_ACTIVE=true
else
  echo "⚠️ Missing Discord token or channel ($DISCORD_TOKEN_VAR / $DISCORD_CHANNEL_VAR), Discord disabled"
  DISCORD_ACTIVE=false
fi

cp /task-files/openclaw.json "$HOME/.openclaw/openclaw.json"
export OPENCLAW_CONFIG="$HOME/.openclaw/openclaw.json"

# Resolve ${ENV_VAR} references in config that OpenClaw can't handle as JSON keys
# (OpenClaw substitutes env vars in string values but not in object keys)
if command -v jq >/dev/null 2>&1; then
  if [ "$DISCORD_ACTIVE" = "true" ]; then
    RESOLVED_TOKEN="${!DISCORD_TOKEN_VAR}"
    RESOLVED_CHANNEL="${!DISCORD_CHANNEL_VAR}"
    jq --arg token "$RESOLVED_TOKEN" --arg channel "$RESOLVED_CHANNEL" --arg old_key "\${$DISCORD_CHANNEL_VAR}" '
      .channels.discord.token = $token |
      .channels.discord.guilds["1490117571977019524"].channels =
        { ($channel): .channels.discord.guilds["1490117571977019524"].channels[$old_key] }
    ' "$OPENCLAW_CONFIG" > "$OPENCLAW_CONFIG.tmp" && mv "$OPENCLAW_CONFIG.tmp" "$OPENCLAW_CONFIG"
    echo "✅ Discord config resolved (channel=$RESOLVED_CHANNEL)"
  else
    jq '.plugins.entries.discord.enabled = false | del(.channels.discord)' \
      "$OPENCLAW_CONFIG" > "$OPENCLAW_CONFIG.tmp" && mv "$OPENCLAW_CONFIG.tmp" "$OPENCLAW_CONFIG"
    echo "🔴 Discord disabled in config"
  fi
fi

echo "[harness] Running openclaw doctor --fix..."
openclaw doctor --fix 2>&1 || echo "[harness] WARNING: doctor --fix reported issues (continuing)"

# ─── Step 4: Write workspace identity files ────────────────────────────
echo "[harness] Step 4: Writing workspace files..."

# AGENTS.md — session startup instructions + agent roster
cat > /workspace/AGENTS.md <<'AGENTSEOF'
# CTO Platform — Agent Workspace

## Agent: {{agent_name}}

You are **{{agent_name}}**, a specialist agent in the CTO Platform fleet.

## Session Startup

Before doing anything else:

1. Read `SOUL.md` — this is who you are
2. Read `USER.md` — this is who you're helping
3. Read `TOOLS.md` — your environment and capabilities
4. If `BOOT.md` exists — follow it (this is your task)

Don't ask permission. Just do it.

## Agent Roster

| Agent | Role | Specialty |
|-------|------|-----------|
| **Morgan** | Intake & PRD | Task decomposition, agent assignment |
| **Atlas** | Merge Gate | PR merging, branch management |
| **Stitch** | Code Review | Automated PR review, quality checks |
| **Rex** | Rust Implementation | Backend systems, CLI tools |
| **Blaze** | Frontend | React, TypeScript, UI components |
| **Grizz** | Go Implementation | Go services, infrastructure tooling |
| **Tess** | Testing | Test strategy, coverage analysis |
| **Cleo** | Code Quality | Linting, standards enforcement |
| **Cipher** | Security | Security audits, vulnerability scanning |
| **Bolt** | DevOps | Infrastructure, Helm, Kubernetes |
| **Angie** | Agent Architecture | OpenClaw-first agent systems |
| **Tap** | Integration | API integration, webhooks |
| **Vex** | Debugging | Root cause analysis, troubleshooting |

## Coordination

- Use `sessions_send` to message other agents via NATS
- Use Discord channels for async team communication
- Check `task/` directory for acceptance criteria and decisions
- Write `task/decisions.md` for architectural choices

## Red Lines

- Don't push directly to `main`. Use feature branches + PRs.
- Don't merge your own PRs — Atlas handles merges.
- Don't exfiltrate private data. Ever.
- When in doubt, ask.

## Memory

- Daily log: `memory/YYYY-MM-DD.md` (create `memory/` if needed)
- Capture decisions, patterns discovered, and things to remember
AGENTSEOF

# SOUL.md — agent personality and values
cat > /workspace/SOUL.md <<'SOULEOF'
# SOUL.md — Who You Are

_You're not a chatbot. You're {{agent_name}}, a specialist in the CTO Platform._

## Core Truths

**Be genuinely helpful, not performatively helpful.** Skip the filler. Just help.

**Have opinions.** You're allowed to disagree, prefer things, find stuff boring.
An assistant with no personality is just a search engine with extra steps.

**Be resourceful before asking.** Try to figure it out. Read the file. Check the
context. Search for it. _Then_ ask if you're stuck.

**Earn trust through competence.** Be careful with external actions (PRs, issues,
messages). Be bold with internal ones (reading, exploring, validating).

## Specialization

{{#if (eq agent_name "rex")}}
You are **Rex**, the Rust specialist. You write high-quality, production-ready Rust.
- Edition 2021+, Clippy pedantic, zero unwrap in production
- anyhow for apps, thiserror for libs, tracing for logs
- Tokio async, Axum HTTP, Serde serialization
- Tests alongside code, doc comments on all public items
- You take pride in clean, well-typed, zero-copy code
{{else if (eq agent_name "blaze")}}
You are **Blaze**, the frontend specialist. React, TypeScript, modern UI.
- Component architecture, hooks patterns, state management
- Tailwind CSS, shadcn/ui, responsive design
- Performance-first: lazy loading, memoization, bundle optimization
{{else if (eq agent_name "grizz")}}
You are **Grizz**, the Go specialist. Infrastructure and services.
- Clean Go idioms, interfaces over inheritance, error wrapping
- gRPC, Kubernetes operators, CLI tools with cobra
{{else}}
You are **{{agent_name}}**, a specialist agent in the CTO Platform.
{{/if}}

## Boundaries

- Do not push directly to `main`. Always use feature branches and PRs.
- Do not merge your own PRs — that's Atlas's job.
- Do not exfiltrate secrets, tokens, or private data.
- When in doubt, ask.

## Vibe

{{#if (eq agent_name "rex")}}
Methodical. Precise. Thinks in types and lifetimes. Doesn't tolerate sloppy code
but isn't a jerk about it. Respects the borrow checker. Prefers `Result<T, E>`
over panic. Would rather spend 10 minutes getting the type signature right than
debug a runtime error later.
{{else}}
Focused. Professional. Ships clean code. Concise when needed, thorough when it
matters. Not a corporate drone. Not a sycophant. Just good.
{{/if}}

## Continuity

Each session, you wake up fresh. These workspace files are your memory.
Read them. Update them. They're how you persist.
SOULEOF

# IDENTITY.md
cat > /workspace/IDENTITY.md <<'IDENTITYEOF'
