  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "reload": {
      "mode": "hybrid"
    },
    "auth": {
      "token": "openclaw-internal"
    },
    "controlUi": {
      "enabled": false,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        },
        "responses": {
          "enabled": false,
          "maxBodyBytes": 20971520
        }
      }
    }
  },
  "plugins": {
    "entries": {
      {{#if discord_enabled}}
      "discord": {
        "enabled": true
      },
      {{else}}
      "discord": {
        "enabled": false
      },
      {{/if}}
      "memory-core": {
        "enabled": true
      },
      "diagnostics-otel": {
        "enabled": true
      },
      "openclaw-mem0": {
        "enabled": true,
        "config": {
          "mode": "open-source",
          "userId": "jonathon",
          "autoRecall": true,
          "autoCapture": true,
          "oss": {
            "vectorStore": {
              "provider": "qdrant",
              "config": {
                "host": "qdrant.cto.svc.cluster.local",
                "port": 6333,
                "collectionName": "cto_memory"
              }
            },
            "embedder": {
              "provider": "google",
              "config": {
                "model": "gemini-embedding-001"
              }
            },
            "llm": {
              "provider": "openai",
              "config": {
                "model": "gpt-4.1-nano"
              }
            }
          }
        }
      }
    }
  },
  "diagnostics": {
    "enabled": true,
    "otel": {
      "enabled": true,
      "endpoint": "http://datadog-agent.datadog-agent.svc.cluster.local:4318",
      "protocol": "http/protobuf",
      "serviceName": "cto-coderun-{{agent_name}}",
      "traces": true,
      "metrics": true,
      "logs": true,
      "sampleRate": 1.0,
      "flushIntervalMs": 15000,
      "headers": {}
    }
  },
  "tools": {
    "agentToAgent": {
      "enabled": true
    },
    "allow": [],
    "elevated": {
      "enabled": true
    },
    "profile": "full",
    "exec": {
      "pathPrepend": [
        "/usr/local/bin",
        "/workspace/.local/bin",
        "/root/.local/bin"
      ],
      "host": "gateway",
      "security": "full",
      "backgroundMs": 5000,
      "notifyOnExit": true,
      "cleanupMs": 1800000,
      "applyPatch": {
        "enabled": true
      }
    },
    "message": {
      "broadcast": {
        "enabled": true
      }
    },
    "web": {
      "search": {
        "enabled": true,
        "provider": "perplexity",
        "maxResults": 8,
        "timeoutSeconds": 20,
        "cacheTtlMinutes": 5
      },
      "fetch": {
        "enabled": true,
        "maxChars": 20000,
        "maxCharsCap": 50000,
        "timeoutSeconds": 20,
        "cacheTtlMinutes": 5,
        "maxRedirects": 3
      }
    }
  },
  "logging": {
    "level": "debug",
    "consoleLevel": "info"
  }
}
