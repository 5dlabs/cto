{{!
  OpenClaw Gateway Configuration (per-CRD)

  Rendered by the controller for each CodeRun.
  Mounted as openclaw.json in the ConfigMap.
  Matches Morgan's Helm-managed config structure (v2026.4.x accounts format).

  Context variables:
    agent_name          - Agent identity (rex, blaze, tap, etc.)
    agent_name_upper    - Agent name uppercased (REX, BLAZE, TAP, etc.)
    model               - Primary model ID (e.g. fireworks/accounts/fireworks/routers/kimi-k2p5-turbo)
    cli_type            - CLI backend for acpx (claude, codex, cursor, factory, etc.)
    service             - Target repo/service name
    task_id             - Task ID from CRD
    github_app          - GitHub App name (e.g. 5DLabs-Rex)
    openclaw_providers  - Array of provider objects from CRD (or defaults)
      .name         - Provider slug (JSON key in models.providers)
      .baseUrl      - API base URL
      .apiKeyEnvVar - Env var name for API key
      .api          - OpenClaw API adapter (e.g. "openai-completions")
      .models[]     - Array of model objects
        .id           - Model identifier
        .name         - Display name
        .reasoning    - Boolean
        .input        - Array of input modalities
        .contextWindow - Token limit
        .maxTokens    - Max output tokens

  Secrets are referenced as env vars (injected by K8s secret mounts):
    DISCORD_TOKEN_<AGENT>   - Per-agent Discord bot token
    DISCORD_CHANNEL_<AGENT> - Per-agent Discord channel ID
}}
{
  "agents": {
    "defaults": {
      "compaction": {
        "memoryFlush": {
          "enabled": true,
          "prompt": "Before this conversation is compacted, write lasting notes to memory/YYYY-MM-DD.md. Include: ongoing tasks, decisions made, user preferences learned, key context. Be specific and concise. If nothing meaningful to store, reply NO_REPLY.",
          "softThresholdTokens": 1000
        },
        "mode": "safeguard",
        "reserveTokensFloor": 25000,
        "maxHistoryShare": 0.5,
        "recentTurnsPreserve": 4
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h",
        "keepLastAssistants": 6,
        "softTrimRatio": 0.75,
        "hardClearRatio": 0.95,
        "minPrunableToolChars": 800
      },
      "elevatedDefault": "full",
      "heartbeat": {
        "every": "15m",
        "target": "last",
        "ackMaxChars": 500,
        "prompt": "Check for pending tasks and execute autonomously. Ask only when genuinely blocked or when a decision requires user preferences you cannot infer. Reply HEARTBEAT_OK only if nothing needs attention."
      },
      "model": {
        "primary": "{{model}}",
        "fallbacks": [
          "google/gemini-2.5-pro"
        ]
      },
      "maxConcurrent": 4,
      "thinkingDefault": "low",
      "timeoutSeconds": 600,
      "mediaMaxMb": 5,
      "typingMode": "instant",
      "typingIntervalSeconds": 5,
      "bootstrapMaxChars": 20000,
      "contextTokens": 200000,
      "subagents": {
        "maxConcurrent": 4,
        "archiveAfterMinutes": 60
      },
      "cliBackends": {
        "claude": {
          "args": [],
          "command": "/usr/local/bin/claude",
          "input": "arg",
          "maxPromptArgChars": 8000,
          "output": "text"
        },
        "code": {
          "args": [],
          "command": "/usr/local/bin/code",
          "output": "text"
        },
        "codex": {
          "args": [],
          "command": "/usr/local/bin/codex",
          "output": "text"
        },
        "cursor": {
          "args": [],
          "command": "/usr/local/bin/cursor-agent",
          "output": "text"
        },
        "gemini": {
          "args": ["--experimental-acp"],
          "command": "/usr/local/bin/gemini",
          "output": "text"
        },
        "kimi": {
          "args": [],
          "command": "/usr/local/bin/kimi",
          "output": "text"
        },
        "opencode": {
          "args": [],
          "command": "/usr/local/bin/opencode",
          "output": "text"
        }
      },
      "workspace": "/workspace"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      {{#each openclaw_providers}}
      "{{this.name}}": {
        "baseUrl": "{{this.baseUrl}}",
        "apiKey": "${{{this.apiKeyEnvVar}}}",
        "api": "{{this.api}}",
        "models": [
          {{#each this.models}}
          {
            "id": "{{this.id}}",
            "name": "{{this.name}}",
            "reasoning": {{this.reasoning}},
            "input": {{{this.input_json}}},
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": {{this.contextWindow}},
            "maxTokens": {{this.maxTokens}}
          }{{#unless @last}},{{/unless}}
          {{/each}}
        ]
      }{{#unless @last}},{{/unless}}
      {{/each}}
    }
  },
  "channels": {
    {{#if discord_enabled}}
    "discord": {
