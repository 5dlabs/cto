# =========================================================================
# OpenAI Codex CLI Invocation Partial
# 
# This partial handles ONLY the Codex CLI command building and execution.
# Include this in workflow containers using the cli_execute partial reference.
#
# Required context variables:
#   - CLAUDE_WORK_DIR: Working directory for execution (uses CODEX_WORK_DIR internally)
#   - PROMPT_CONTENT: The prompt to send (or read from task/prompt.md)
#
# Optional context variables:
#   - model: Model to use (e.g., gpt-5-codex)
#   - sandbox_mode: read-only, workspace-write, danger-full-access (default: workspace-write)
#   - approval_mode: untrusted, on-failure, on-request, never (default: on-failure)
#   - full_auto: If true, sets workspace-write sandbox + on-failure approvals
#   - enable_search: If true, enables web search capability
#   - add_dirs: Additional directories to grant write access
# =========================================================================

echo "═══════════════════════════════════════════════════════════════"
echo "║               OPENAI CODEX CLI INVOCATION                    ║"
echo "═══════════════════════════════════════════════════════════════"

# Build Codex command with latest CLI flags (as of Dec 2024)
# Reference: https://developers.openai.com/codex/cli/reference/
CODEX_CMD=("codex" "exec")

# Working directory
CODEX_WORK_DIR="${CLAUDE_WORK_DIR:-/workspace}"
CODEX_CMD+=("--cd" "$CODEX_WORK_DIR")

# Sandbox mode — use danger-full-access in Kubernetes (bwrap unavailable without SYS_ADMIN)
SANDBOX_MODE="{{#if sandbox_mode}}{{sandbox_mode}}{{else}}danger-full-access{{/if}}"
CODEX_CMD+=("--sandbox" "$SANDBOX_MODE")
echo "✓ Sandbox mode: $SANDBOX_MODE"

# Model override — strip provider prefix (e.g. "openai-codex/o4-mini" → "o4-mini")
# Skip model flag if using ChatGPT OAuth (auth_mode=chatgpt); let the plan default apply.
# Only pass explicit --model for known short model ids without a provider prefix.
{{#if model}}
MODEL_RAW="{{model}}"
MODEL_NAME="${MODEL_RAW##*/}"
# If the raw value had a provider prefix, use the stripped name only if it's a known model id
# (no slashes, not an internal codename like gpt-5.3-codex)
if echo "$MODEL_NAME" | grep -qE '^(o3|o4-mini|o3-mini|codex-mini-latest)$'; then
    CODEX_CMD+=("--model" "$MODEL_NAME")
    echo "✓ Model: $MODEL_NAME"
else
    echo "✓ Model: chatgpt plan default (skipping internal id: {{model}})"
fi
{{/if}}

# JSON output for streaming
CODEX_CMD+=("--json")

# Web search capability
{{#if enable_search}}
CODEX_CMD+=("--search")
echo "✓ Web search enabled"
{{/if}}

# Additional directories with write access
{{#if add_dirs}}
{{#each add_dirs}}
CODEX_CMD+=("--add-dir" "{{this}}")
{{/each}}
echo "✓ Additional directories: {{add_dirs}}"
{{/if}}

# Dangerous mode for fully isolated environments only
{{#if dangerous_bypass}}
CODEX_CMD+=("--dangerously-bypass-approvals-and-sandbox")
echo "⚠️ DANGEROUS: Bypassing all approvals and sandbox"
{{/if}}

# Copy skills to .codex/skills/ for native skill discovery
{{> skills-setup skills_target="$CODEX_WORK_DIR/.codex/skills" skills_label="OpenAI Codex" }}

# Determine prompt source
if [ -n "${PROMPT_CONTENT:-}" ]; then
    PROMPT_TEXT="$PROMPT_CONTENT"
elif [ -f "$CODEX_WORK_DIR/task/prompt.md" ]; then
    PROMPT_TEXT=$(cat "$CODEX_WORK_DIR/task/prompt.md")
    echo "✓ Using prompt from task/prompt.md"
else
    echo "❌ ERROR: No prompt content available"
    exit 1
fi

# Add prompt as the final argument
CODEX_CMD+=("$PROMPT_TEXT")

echo ""
echo "🚀 Codex Command:"
echo "   codex exec --cd $CODEX_WORK_DIR [options] \"<prompt>\""
echo ""

# Execute Codex
echo "Starting Codex execution..."
"${CODEX_CMD[@]}"
CODEX_EXIT_CODE=$?

echo ""
echo "✓ Codex execution completed (exit code: $CODEX_EXIT_CODE)"

