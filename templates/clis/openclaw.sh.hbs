# =========================================================================
# OpenClaw ACP Agent Invocation
#
# Universal entrypoint — OpenClaw dispatches to the correct CLI harness
# (codex-acp, claude-agent-acp, opencode, cursor, etc.) via the acpx plugin.
#
# All CLI-specific logic lives in OpenClaw config, not in this template.
#
# Required context variables:
#   - CLAUDE_WORK_DIR: Working directory
#   - PROMPT_CONTENT: Task prompt (or read from task/prompt.md)
#
# Optional context variables:
#   - cli_type: Backend harness to use (codex, claude, opencode, cursor, ...)
#               defaults to "codex"
#   - model:    Model hint passed to the harness (optional)
# =========================================================================

echo "═══════════════════════════════════════════════════════════════"
echo "║               OPENCLAW ACP AGENT INVOCATION                  ║"
echo "═══════════════════════════════════════════════════════════════"

WORK_DIR="${CLAUDE_WORK_DIR:-/workspace}"
AGENT_BACKEND="{{#if cli_type}}{{cli_type}}{{else}}codex{{/if}}"
echo "✓ Work dir:  $WORK_DIR"
echo "✓ Backend:   $AGENT_BACKEND"

# =========================================================================
# Resolve OpenClaw model from CodeRun CRD parameters
# The controller passes {{cli_type}} and {{model}} from the CRD spec.
# We map cli_type → OpenClaw provider that has valid auth in the pod.
# =========================================================================
CLI_TYPE="{{cli_type}}"
CRD_MODEL="{{model}}"

# Map CLI type → OpenClaw model provider
# openai-api = standard OpenAI API (OPENAI_API_KEY)
# openai-codex = ChatGPT OAuth backend (needs OAuth token, not API key)
case "$CLI_TYPE" in
  codex)     PROVIDER="openai-api" ;;
  cursor)    PROVIDER="openai-api" ;;
  factory)   PROVIDER="openai-api" ;;
  claude)    PROVIDER="anthropic" ;;
  gemini)    PROVIDER="gemini" ;;
  opencode)  PROVIDER="openrouter" ;;
  *)         PROVIDER="openai-api" ;;
esac

OPENCLAW_MODEL="${PROVIDER}/${CRD_MODEL}"
echo "✓ Agent model: $OPENCLAW_MODEL (cli=$CLI_TYPE, model=$CRD_MODEL)"

# =========================================================================
# Skills Setup
# =========================================================================
{{> skills-setup skills_target="$WORK_DIR/.openclaw/skills" skills_label="OpenClaw ACP" }}

# =========================================================================
# Write openclaw.json — OpenClaw reads config from ~/.openclaw/openclaw.json
# Include model provider definitions so older OpenClaw versions work.
# =========================================================================
OPENCLAW_HOME="${HOME}/.openclaw"
mkdir -p "$OPENCLAW_HOME"

cat > "$OPENCLAW_HOME/openclaw.json" << OPENCLAW_CFG
{
  "agents": {
    "defaults": {
      "model": {
        "primary": "$OPENCLAW_MODEL",
        "fallbacks": []
      }
    }
  },
  "models": {
    "providers": {
      "openai-api": {
        "baseUrl": "https://api.openai.com/v1",
        "api": "openai-responses",
        "auth": "token",
        "authHeader": true,
        "models": [
          { "id": "gpt-5.4", "name": "GPT-5.4", "reasoning": true, "input": ["text","image"], "contextWindow": 1000000, "maxTokens": 65536 },
          { "id": "gpt-5.4-pro", "name": "GPT-5.4 Pro", "reasoning": true, "input": ["text","image"], "contextWindow": 1000000, "maxTokens": 65536 },
          { "id": "gpt-4.1", "name": "GPT-4.1", "reasoning": false, "input": ["text","image"], "contextWindow": 1000000, "maxTokens": 32768 }
        ]
      },
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "api": "anthropic-messages",
        "auth": "token",
        "authHeader": true,
        "models": [
          { "id": "claude-sonnet-4-6", "name": "Claude Sonnet 4.6", "reasoning": true, "input": ["text","image"], "contextWindow": 200000, "maxTokens": 64000 },
          { "id": "claude-opus-4-6", "name": "Claude Opus 4.6", "reasoning": true, "input": ["text","image"], "contextWindow": 200000, "maxTokens": 64000 }
        ]
      }
    }
  }
}
OPENCLAW_CFG

echo "✓ Wrote $OPENCLAW_HOME/openclaw.json (model: $OPENCLAW_MODEL, no fallbacks)"

# =========================================================================
# Onboard auth — register API keys with OpenClaw's auth store
# openclaw onboard writes auth-profiles.json so the agent can use the key.
# =========================================================================
if [ -n "${OPENAI_API_KEY:-}" ]; then
  openclaw onboard --openai-api-key "$OPENAI_API_KEY" 2>/dev/null && \
    echo "✓ Onboarded OpenAI API key" || echo "⚠️ OpenAI onboard failed (non-fatal)"
fi
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  openclaw onboard --anthropic-api-key "$ANTHROPIC_API_KEY" 2>/dev/null && \
    echo "✓ Onboarded Anthropic API key" || echo "⚠️ Anthropic onboard failed (non-fatal)"
fi

# =========================================================================
# Determine prompt
# =========================================================================
if [ -n "${PROMPT_CONTENT:-}" ]; then
    PROMPT_TEXT="$PROMPT_CONTENT"
elif [ -f "$WORK_DIR/task/prompt.md" ]; then
    PROMPT_TEXT=$(cat "$WORK_DIR/task/prompt.md")
    echo "✓ Using prompt from task/prompt.md"
else
    echo "❌ ERROR: No prompt content available"
    exit 1
fi

echo ""
echo "🚀 Launching: openclaw agent --local --session-id coderun-{{task_id}}-{{agent_name}}-{{cli_type}} --message <prompt>"
echo ""

# =========================================================================
# Execute — OpenClaw runs locally, dispatches to the ACP harness
# cd into work dir so OpenClaw picks up .openclaw/openclaw.json from CWD
# =========================================================================
cd "$WORK_DIR"
openclaw agent \
    --local \
    --session-id "coderun-{{task_id}}-{{agent_name}}-{{cli_type}}" \
    --message "$PROMPT_TEXT"

OPENCLAW_EXIT=$?
echo ""
echo "✓ OpenClaw ACP execution completed (exit code: $OPENCLAW_EXIT)"
