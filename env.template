# =============================================================================
# env.template - Environment Variables for Local Development
# =============================================================================
# Copy this file to .env.local and fill in the values.
# The .env.local file is gitignored and should not be committed.
#
# Alternatively, run: ./scripts/sync-secrets-for-dev.sh
# to automatically fetch secrets from 1Password.
#
# Usage:
#   cp env.template .env.local
#   # Edit .env.local with your values
#   source .env.local
#   just dev
#
# =============================================================================

# =============================================================================
# Kubernetes Configuration
# =============================================================================
# Path to your kubeconfig file (usually auto-detected)
# export KUBECONFIG="$HOME/.kube/config"

# Namespace for CTO platform resources
export NAMESPACE="cto"
export KUBERNETES_NAMESPACE="cto"

# Logging level (adjust as needed)
export RUST_LOG="info,controller=debug,pm=debug,healer=debug,tools=debug"

# =============================================================================
# AI Provider API Keys (required)
# =============================================================================
# Source: OpenBao path `api-keys`
# These are required for AI operations in various services.

# Anthropic/Claude API - Primary AI provider
export ANTHROPIC_API_KEY=""

# OpenAI API - Alternative provider
export OPENAI_API_KEY=""

# Google Gemini API
export GEMINI_API_KEY=""

# Google Cloud API (for other Google services)
export GOOGLE_API_KEY=""

# Cursor IDE API
export CURSOR_API_KEY=""

# Context7 - Library documentation lookups
export CONTEXT7_API_KEY=""

# Perplexity - Web search integration
export PERPLEXITY_API_KEY=""

# xAI/Grok API
export XAI_API_KEY=""

# Factory AI API
export FACTORY_API_KEY=""

# Brave Search API
export BRAVE_API_KEY=""

# MiniMax AI Suite
export MINIMAX_API_KEY=""
export MINIMAX_GROUP_ID=""

# =============================================================================
# Linear Integration (required for PM server)
# =============================================================================
# Source: OpenBao path `linear-sync`

# Enable Linear integration
export LINEAR_ENABLED="true"

# Linear server port
export LINEAR_PORT="8081"

# Linear team ID
export LINEAR_TEAM_ID="CTOPA"

# Linear API Key
export LINEAR_API_KEY=""

# Linear OAuth credentials
export LINEAR_CLIENT_ID=""
export LINEAR_CLIENT_SECRET=""
export LINEAR_OAUTH_TOKEN=""
export LINEAR_WEBHOOK_SECRET=""

# =============================================================================
# GitHub Integration (required)
# =============================================================================
# Source: OpenBao path `tools-github`

# GitHub Personal Access Token (used by multiple services)
# Requires scopes: repo, read:org, workflow
export GITHUB_TOKEN=""
export GITHUB_PERSONAL_ACCESS_TOKEN=""
export GH_TOKEN=""  # For gh CLI

# =============================================================================
# Firecrawl (required for web scraping)
# =============================================================================
# Source: OpenBao path `tools-firecrawl`

export FIRECRAWL_API_KEY=""

# =============================================================================
# Latitude.sh (optional - for bare metal management)
# =============================================================================
# Source: OpenBao path `tools-latitude`

export LATITUDE_API_KEY=""

# =============================================================================
# Twitter Research (optional - only for research CLI)
# =============================================================================
# Source: OpenBao path `research-twitter`
# These are browser session cookies from twitter.com

export TWITTER_AUTH_TOKEN=""
export TWITTER_CT0=""

# =============================================================================
# Service Configuration
# =============================================================================

# --- Controller Service ---
export SERVER_HOST="0.0.0.0"
export SERVER_PORT="8080"
export AGENT_TEMPLATES_PATH="./templates"

# --- Healer Service ---
export HEALER_TEMPLATES_DIR="./templates/healer"
export CTO_CONFIG_PATH="./cto-config.json"

# --- Tools Service ---
export PORT="3000"
export SYSTEM_CONFIG_PATH="./infra/charts/cto/templates/tools"

# =============================================================================
# Optional: Per-Agent Linear OAuth Apps
# =============================================================================
# These are only needed if you're testing Linear agent integrations locally.
# Each agent has its own Linear OAuth app for unique identity.
# Source: OpenBao paths `linear-app-{agent}`

# Example for Morgan agent:
# export LINEAR_APP_MORGAN_CLIENT_ID=""
# export LINEAR_APP_MORGAN_CLIENT_SECRET=""
# export LINEAR_APP_MORGAN_WEBHOOK_SECRET=""
# export LINEAR_APP_MORGAN_ACCESS_TOKEN=""

