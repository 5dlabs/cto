{
  "servers": {
    "filesystem": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "env": {}
    },
    "memory": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {}
    },
    "context7": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "workingDirectory": "/tmp",
      "env": {
        "CONTEXT7_API_KEY": "test-key-placeholder"
      }
    },
    "github": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "workingDirectory": "/tmp",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_test-placeholder"
      }
    },
    "openmemory": {
      "transport": "http",
      "url": "http://localhost:8080/mcp"
    },
    "ai-elements": {
      "transport": "http",
      "url": "https://registry.ai-sdk.dev/api/mcp"
    }
  }
}
