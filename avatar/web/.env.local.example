# LiveKit server credentials used by app/api/token/route.ts
LIVEKIT_URL=wss://lk.5dlabs.ai
LIVEKIT_API_KEY=lkapi_your_key
LIVEKIT_API_SECRET=your_secret

# --- Optional: TalkingHead 3D runtime ---
# Set to `talkinghead` to render the WebGL avatar; omit for the deterministic portrait.
# Lip-sync is driven in-browser by HeadAudio on the LiveKit audio stream — no
# voice-bridge or server TTS alignment is needed for mouth movement.
NEXT_PUBLIC_AVATAR_RUNTIME=talkinghead
# Mixamo-compatible .glb with ARKit 52 + Oculus 15 visemes. Generate one at
# https://readyplayer.me or use the TalkingHead demo sample below (CC BY-NC).
NEXT_PUBLIC_AVATAR_GLB_URL=https://met4citizen.github.io/TalkingHead/avatars/brunette.glb
