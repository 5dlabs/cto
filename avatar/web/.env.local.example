# LiveKit server credentials used by app/api/token/route.ts
LIVEKIT_URL=wss://lk.5dlabs.ai
LIVEKIT_API_KEY=lkapi_your_key
LIVEKIT_API_SECRET=your_secret

# --- Optional: deterministic fallback cues ---
# Remote LiveKit video from LemonSlice or EchoMimic is preferred whenever the
# worker publishes a video track. Set this only to keep the fallback portrait and
# derive rough text cues from bridge frames.
# NEXT_PUBLIC_AVATAR_RUNTIME=derived-text

# --- Optional: EchoMimic turn demo (/echo-turn) ---
# Server-only URL for the EchoMimic FastAPI app. The browser calls the local
# Next.js proxy route, not this URL directly.
ECHOMIMIC_APP_URL=https://your-echomimic-app.app.gra.ai.cloud.ovh.net

# Optional real model/TTS streaming. If omitted, /echo-turn uses a deterministic
# streamed fallback response and voice_clone_sample.mp3 so the UI can run locally.
MORGAN_GATEWAY_URL=http://openclaw-morgan.cto.svc.cluster.local:18789
MORGAN_GATEWAY_TOKEN=openclaw-internal
MORGAN_MODEL=openclaw/morgan
# Optional aliases matching the Python LiveKit/OpenClaw worker env. Use these
# when targeting a shared OpenClaw gateway instead of a dedicated Morgan URL.
MORGAN_LLM_BASE_URL=https://morgan.5dlabs.ai/v1
MORGAN_LLM_AGENT_ID=morgan
OPENCLAW_TOKEN=openclaw-internal
ELEVENLABS_API_KEY=your_elevenlabs_key
MORGAN_VOICE_ID=iP95p4xoKVk53GoZ742B
