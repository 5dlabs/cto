{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "decision-point.schema.json",
  "title": "DecisionPoint",
  "description": "A strategic decision point capturing an architectural or design choice that needs resolution. Decision points represent choices between fundamentally different approaches — not implementation details that should follow best practices.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "architecture",
        "language-runtime",
        "service-topology",
        "platform-choice",
        "build-vs-buy",
        "data-model",
        "api-design",
        "ux-behavior",
        "visual-identity",
        "design-system",
        "component-library",
        "layout-pattern",
        "security"
      ]
    },
    "description": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_approval": {
      "type": "boolean"
    },
    "constraint_type": {
      "type": "string",
      "enum": ["hard", "soft", "open", "escalation"]
    }
  },
  "required": [
    "id",
    "category",
    "description",
    "options",
    "requires_approval",
    "constraint_type"
  ],
  "additionalProperties": false
}
