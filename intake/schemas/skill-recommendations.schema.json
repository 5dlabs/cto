{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillRecommendations",
  "description": "LLM-matched skill recommendations per task based on clawhub search results",
  "type": "object",
  "properties": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task_id": { "type": "number", "description": "Task ID matching the expanded task" },
          "agent": { "type": "string", "description": "Assigned agent name" },
          "recommended_skills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "skill_slug": { "type": "string", "description": "ClawHub skill identifier" },
                "reason": { "type": "string", "description": "Why this skill is relevant to the task" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Confidence score 0-1" }
              },
              "required": ["skill_slug", "reason", "confidence"]
            }
          },
          "gaps": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Technologies or capabilities needed but not found in skill search results"
          }
        },
        "required": ["task_id", "agent", "recommended_skills"]
      }
    }
  },
  "required": ["recommendations"]
}
