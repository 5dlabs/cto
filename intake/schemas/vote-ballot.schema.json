{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vote-ballot.schema.json",
  "title": "VoteBallot",
  "description": "A voting committee ballot for evaluating generated task output quality.",
  "type": "object",
  "properties": {
    "voter_id": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "properties": {
        "task_decomposition": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "dependency_ordering": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "decision_point_coverage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "test_strategy_quality": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "agent_assignment": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      },
      "required": [
        "task_decomposition",
        "dependency_ordering",
        "decision_point_coverage",
        "test_strategy_quality",
        "agent_assignment"
      ],
      "additionalProperties": false
    },
    "overall_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "verdict": {
      "type": "string",
      "enum": ["approve", "revise", "reject"]
    },
    "reasoning": {
      "type": "string"
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "voter_id",
    "scores",
    "overall_score",
    "verdict",
    "reasoning",
    "suggestions"
  ],
  "additionalProperties": false
}
