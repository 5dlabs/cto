{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "generated-task.schema.json",
  "title": "GeneratedTaskArray",
  "description": "An array of generated tasks from parse_prd output.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/generated_task"
  },
  "$defs": {
    "generated_task": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "done", "blocked", "deferred"]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "agent": {
          "type": "string",
          "description": "Agent name responsible for this task (bolt, rex, grizz, nova, blaze, tap, spark, cipher, tess, cleo, atlas, stitch, angie)",
          "enum": ["bolt", "rex", "grizz", "nova", "blaze", "tap", "spark", "cipher", "tess", "cleo", "atlas", "stitch", "angie"]
        },
        "stack": {
          "type": "string",
          "description": "Primary tech stack for this task (e.g., Kubernetes, Rust/Axum, React/Next.js)"
        },
        "details": {
          "type": "string"
        },
        "test_strategy": {
          "type": "string"
        },
        "subtasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "./generated-subtask.schema.json"
          }
        },
        "decision_points": {
          "type": "array",
          "items": {
            "$ref": "./decision-point.schema.json"
          }
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "dependencies",
        "agent",
        "subtasks"
      ],
      "additionalProperties": false
    }
  }
}
