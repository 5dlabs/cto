# Pointer-only map → copied to intake/local.env.op on first run (gitignored) by
# ensure-local-env-op.sh. Lines are 1Password references, not plaintext secrets.
#
# Linear: use OAuth access token (Morgan app), NOT lin_api_* personal API keys.
# The bridge sends Bearer <token> automatically when the value does not start with lin_api_.
LINEAR_API_KEY=op://Automation/Linear Morgan OAuth/developer_token

# Discord HTTP bridge: intake bot from OpenClaw pooled tokens (same bots cluster uses).
DISCORD_BRIDGE_TOKEN=op://Automation/OpenClaw Discord Tokens/DISCORD_TOKEN_INTAKE

# TTS providers: lobster-voice cascades ElevenLabs → OpenAI → xAI.
ELEVEN_API_KEY=op://Automation/ElevenLabs API Key/credential
OPENAI_API_KEY=op://Automation/OpenAI API Key/credential
XAI_API_KEY=op://Automation/xAI API Key/credential

# Google Stitch: design intake generates UI candidates via the Stitch SDK.
STITCH_API_KEY=op://Automation/Google Stitch API Key/credential

# LLM provider cascade: openclaw.invoke tries OpenRouter → Gemini → MiniMax → Anthropic → OpenAI.
OPENROUTER_API_KEY=op://Automation/Open Router API Key/notesPlain
MINIMAX_API_KEY=op://Automation/MiniMax API Credentials/MINIMAX_API_KEY
GEMINI_API_KEY=op://Automation/Google-Gemini API Key/credential
ANTHROPIC_API_KEY=op://Automation/4cdtiaovfohm2m5mnmmbpa2no4/credential

# Vertex AI (Claude Opus / Sonnet partner models) — uses GCP ADC, not GEMINI_API_KEY.
# After `gcloud auth login`, set project (or add a 1Password field and reference here):
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Microsoft Azure OpenAI / Foundry (jonathon-0121). Create the item first:
#   ./intake/scripts/create-azure-openai-op-item.sh
# (requires op CLI write access to the Automation vault). Then uncomment:
# AZURE_OPENAI_API_KEY=op://Automation/Azure OpenAI Foundry (jonathon-0121)/credential
# AZURE_OPENAI_BASE_URL=op://Automation/Azure OpenAI Foundry (jonathon-0121)/hostname

# Elicitation: auto-accept committee recommendation after N seconds of inactivity.
# Set to 0 to wait forever (requires human present in Discord/Linear).
ELICITATION_TIMEOUT_SECONDS=300

# Design review: longer timeout for design variant selection (default 30 min).
DESIGN_REVIEW_TIMEOUT_SECONDS=1800

# Local dev (run-local-bridges.sh sets these if unset):
DISCORD_BRIDGE_URL=http://127.0.0.1:3200
LINEAR_BRIDGE_URL=http://127.0.0.1:3100
#
# LINEAR_TEAM_ID is optional in this file — ./intake/scripts/run-local-bridges.sh and
# ./intake/scripts/linear-resolve-team-id.sh derive the UUID from defaults.linear.teamId
# in cto-config.json (e.g. CTOPA) via the same GraphQL teams list as the Linear UI.
