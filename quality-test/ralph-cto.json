{
  "version": 1,
  "project": {
    "name": "cto-code-quality",
    "description": "Systematic code quality improvements using Clippy pedantic, CODE_QUALITY_ANALYSIS.md findings",
    "repository": "5dlabs/cto",
    "branch": "ralph/code-quality"
  },
  "paths": {
    "prdPath": "quality-test/prd.json",
    "execPromptPath": "quality-test/prompt.md",
    "objectivePath": "quality-test/current-objective.md",
    "progressPath": "quality-test/progress.txt",
    "reportPath": "quality-test/report.json",
    "statePath": "quality-test/ralph-cto.state.json",
    "analysisPath": "docs/CODE_QUALITY_ANALYSIS.md"
  },
  "runner": {
    "cli": "claude",
    "command": "claude --dangerously-skip-permissions -p"
  },
  "attended": {
    "enabled": true,
    "requiredRuns": 1
  },
  "infinite": {
    "enabled": true,
    "cooldownSeconds": 30,
    "successCooldownSeconds": 60,
    "maxConsecutiveFailures": 5,
    "enableRemediation": false
  },
  "preflight": {
    "requiredCommands": [
      "cargo",
      "git",
      "rg"
    ],
    "checks": [
      {
        "name": "cargo-available",
        "command": "cargo --version"
      },
      {
        "name": "clippy-available",
        "command": "cargo clippy --version"
      },
      {
        "name": "git-clean",
        "command": "git diff --quiet HEAD || echo 'Uncommitted changes'"
      },
      {
        "name": "on-quality-branch",
        "command": "git rev-parse --abbrev-ref HEAD | grep -q 'ralph/code-quality'"
      }
    ]
  },
  "verification": {
    "afterEachStory": [
      "cargo fmt --all --check",
      "cargo clippy --all-targets -- -D warnings",
      "cargo test --all --lib"
    ],
    "beforeCommit": [
      "cargo fmt --all",
      "cargo clippy --all-targets -- -D warnings"
    ],
    "beforePush": {
      "required": true,
      "failOnError": true,
      "checks": [
        {
          "name": "format-check",
          "command": "cargo fmt --all --check",
          "description": "Code must be properly formatted"
        },
        {
          "name": "clippy-warnings",
          "command": "cargo clippy --all-targets -- -D warnings",
          "description": "No Clippy warnings (standard)"
        },
        {
          "name": "clippy-pedantic",
          "command": "cargo clippy --all-targets -- -W clippy::pedantic 2>&1 | tail -1",
          "description": "Clippy pedantic check (warnings allowed but tracked)"
        },
        {
          "name": "unit-tests",
          "command": "cargo test --all --lib",
          "description": "All library unit tests must pass"
        },
        {
          "name": "doc-tests",
          "command": "cargo test --all --doc",
          "description": "Documentation tests must pass"
        },
        {
          "name": "integration-tests",
          "command": "cargo test --all -- --ignored 2>&1 || echo 'Some integration tests skipped'",
          "description": "Integration tests (best effort, some may require infrastructure)"
        }
      ]
    }
  },
  "phases": [
    {
      "id": "clippy-low-hanging",
      "description": "Address simple Clippy allows that can be fixed without design changes",
      "stories": ["CQ-002", "CQ-003", "CQ-004", "CQ-007", "CQ-008", "CQ-012"],
      "timeoutMinutes": 60,
      "gates": [
        {
          "name": "unused-self-removed",
          "description": "No unused_self allows remaining",
          "command": "rg '#\\[allow\\(clippy::unused_self\\)\\]' crates --count-matches | wc -l | xargs test 0 -eq"
        },
        {
          "name": "all-allows-documented",
          "description": "All remaining allows have reason comments",
          "command": "rg '#\\[allow\\(clippy::' crates | grep -v '//' | wc -l | xargs test 0 -eq"
        }
      ]
    },
    {
      "id": "shell-scripts",
      "description": "Add strict mode to shell scripts",
      "stories": ["CQ-009"],
      "timeoutMinutes": 30,
      "gates": [
        {
          "name": "all-scripts-strict",
          "description": "All shell scripts have set -euo pipefail",
          "command": "find scripts docs -name '*.sh' -exec sh -c 'head -25 \"$1\" | grep -q \"set -e\"' _ {} \\; -print | wc -l | xargs test 0 -eq"
        }
      ]
    },
    {
      "id": "clippy-medium",
      "description": "Address medium-complexity Clippy issues",
      "stories": ["CQ-005", "CQ-006", "CQ-011"],
      "timeoutMinutes": 120,
      "gates": [
        {
          "name": "cast-safety-addressed",
          "description": "Cast safety allows documented or fixed",
          "command": "rg '#\\[allow\\(clippy::cast_' crates --count-matches || echo 0"
        }
      ]
    },
    {
      "id": "code-quality",
      "description": "Address code quality findings from CODE_QUALITY_ANALYSIS.md",
      "stories": ["CQ-010", "CQ-013"],
      "timeoutMinutes": 60,
      "gates": [
        {
          "name": "todo-markers-tracked",
          "description": "TODO markers documented in progress.txt",
          "command": "grep -q 'TODO Audit' quality-test/progress.txt"
        }
      ]
    },
    {
      "id": "high-severity",
      "description": "Address HIGH severity findings from CODE_QUALITY_ANALYSIS.md",
      "stories": ["CQ-015", "CQ-016"],
      "timeoutMinutes": 180,
      "gates": [
        {
          "name": "blocking-io-reduced",
          "description": "std::fs calls in async code reduced",
          "command": "rg 'std::fs::' crates --count-matches | awk -F: '{sum+=$2} END {print sum}' | xargs -I {} test {} -lt 100"
        },
        {
          "name": "unwrap-reduced",
          "description": "unwrap() calls reduced in target files",
          "command": "rg '\\.unwrap\\(\\)' crates/healer/src/ci/router.rs crates/controller/src/cli/adapters/claude.rs --count-matches | awk -F: '{sum+=$2} END {print sum}' | xargs -I {} test {} -lt 50"
        }
      ]
    },
    {
      "id": "medium-severity",
      "description": "Address MEDIUM severity findings - println to tracing",
      "stories": ["CQ-017"],
      "timeoutMinutes": 90,
      "gates": [
        {
          "name": "println-reduced-healer",
          "description": "println! reduced in healer/main.rs",
          "command": "rg 'println!' crates/healer/src/main.rs --count-matches | xargs -I {} test {} -lt 200"
        }
      ]
    },
    {
      "id": "clippy-large",
      "description": "Address larger Clippy refactors",
      "stories": ["CQ-014"],
      "timeoutMinutes": 120,
      "gates": [
        {
          "name": "too-many-lines-reduced",
          "description": "too_many_lines allows reduced",
          "command": "rg '#\\[allow\\(clippy::too_many_lines\\)\\]' crates --count-matches | wc -l | xargs -I {} test {} -lt 60"
        }
      ]
    },
    {
      "id": "final-verification",
      "description": "Final quality gate verification",
      "stories": ["CQ-018"],
      "timeoutMinutes": 60,
      "gates": [
        {
          "name": "format-check",
          "description": "Code is formatted",
          "command": "cargo fmt --all --check"
        },
        {
          "name": "clippy-clean",
          "description": "Clippy warnings pass",
          "command": "cargo clippy --all-targets -- -D warnings"
        },
        {
          "name": "clippy-pedantic-improved",
          "description": "Clippy pedantic warnings reduced from baseline",
          "command": "cargo clippy --all-targets -- -W clippy::pedantic 2>&1 | grep -c 'warning:' | xargs -I {} test {} -lt 240"
        },
        {
          "name": "unit-tests-pass",
          "description": "All unit tests pass",
          "command": "cargo test --all --lib"
        },
        {
          "name": "integration-tests-pass",
          "description": "Integration tests pass",
          "command": "cargo test --all"
        }
      ]
    }
  ],
  "commitStrategy": {
    "afterEachStory": true,
    "pushAfterCommit": true,
    "commitMessagePrefix": "feat(quality):",
    "branchProtection": {
      "requireCI": true,
      "allowForcePush": false
    }
  },
  "metrics": {
    "track": [
      "clippy_allows_count",
      "unwrap_calls",
      "println_calls",
      "todo_markers",
      "test_coverage"
    ],
    "baselinePath": "quality-test/baseline-metrics.json"
  }
}
